# === 飞书开放平台凭证 ===
# 在 https://open.feishu.cn/app 创建自建应用获取
LARK_APP_ID=cli_xxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# === 飞书多维表格（Base） ===
# 多维表格 URL: https://xxx.feishu.cn/base/{base_token}?table={table_id}
# 推荐用「岭南所官网内容库」一个 Base 装 8 张表
LARK_BASE_TOKEN=bascnxxxxxxxxxxxx

# 各表 ID（每张表对应一个 token，URL 里有）
LARK_TABLE_LAWYERS=tblxxxxxxxx
LARK_TABLE_CASES=tblxxxxxxxx
LARK_TABLE_NEWS=tblxxxxxxxx
LARK_TABLE_HONORS=tblxxxxxxxx
LARK_TABLE_PRACTICES=tblxxxxxxxx
LARK_TABLE_OFFICES=tblxxxxxxxx
LARK_TABLE_SOCIAL=tblxxxxxxxx
LARK_TABLE_SITE_CONFIG=tblxxxxxxxx

# === 数据源模式 ===
# auto  : 有凭证则用飞书，否则用本地 mock
# lark  : 强制飞书（无凭证会报错）
# mock  : 强制本地 mock（适合本地预览 / CI）
CONTENT_SOURCE=auto

# === 网站配置（会写入 <head> 和 footer） ===
PUBLIC_SITE_NAME=广东岭南律师事务所
PUBLIC_SITE_NAME_EN=Lingnan · Counsel & Attorneys at Law
PUBLIC_SITE_URL=https://www.lingnanlaw.com
PUBLIC_SITE_FOUNDED=1984
PUBLIC_CONTACT_PHONE=+86-20-8888-0000
PUBLIC_CONTACT_EMAIL=hello@lingnanlaw.com
PUBLIC_CONTACT_ADDRESS=广州市天河区珠江新城华夏路 8 号 合景国际金融广场 35 楼

# === Coze 智能体（全站右下角悬浮） ===
# bot_id: 在 https://www.coze.cn 智能体页面 URL 里获取
# token: 个人访问令牌（https://www.coze.cn/open/oauth/pats），需勾选对应 bot 权限
#       留空则不渲染悬浮按钮
PUBLIC_COZE_BOT_ID=7649212267900616714
PUBLIC_COZE_TOKEN=
