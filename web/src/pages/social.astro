---
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageHero from '~/components/PageHero.astro';
import { getSocial } from '~/lib/content';
import { t, DEFAULT_LOCALE, type Locale } from '~/i18n';

const locale: Locale = (Astro.currentLocale as Locale) || DEFAULT_LOCALE;
const items = await getSocial();
---

<BaseLayout title={t({ zh: '党建公益', en: 'Public Welfare' }, locale)}>
  <PageHero
    eyebrow={t({ zh: 'Party & Public Welfare', en: 'Public Welfare' }, locale)}
    title={t({ zh: '法律人的<br/>另一种担当。', en: 'Another Form<br/>of Service.' }, locale)}
    lede={t({ zh: '积极承担社会责任，热心公益事业。', en: 'Actively embracing social responsibility and public welfare.' }, locale)}
  />

  <section class="section--tight" style="padding-top: 0;">
    <div class="container">
      {items.length === 0 ? (
        <p class="muted" style="text-align: center; padding: 80px 0;">{t({ zh: '公益内容筹备中。', en: 'Content is being prepared.' }, locale)}</p>
      ) : (
        <div class="social-grid">
          {items.map(item => (
            <article class="social-item card">
              <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
                <span class="tag tag--seal">{t(item.category, locale)}</span>
                <span class="muted" style="font-family: var(--serif-en); font-size: 13px; letter-spacing: 0.1em;">{item.date}</span>
              </div>
              <h3 class="card__title">{t(item.title, locale)}</h3>
              {item.location && <div class="card__eyebrow" style="margin-bottom: 12px;">📍 {t(item.location, locale)}</div>}
              <p class="card__excerpt">{t(item.description, locale)}</p>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .social-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(360px, 1fr)); gap: var(--gutter); }
</style>
