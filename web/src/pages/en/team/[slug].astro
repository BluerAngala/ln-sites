---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getLawyers, getLawyerBySlug, getCases } from '~/lib/content';
import { t, ta, type Locale } from '~/i18n';

const locale: Locale = 'en';

export async function getStaticPaths() {
  const lawyers = await getLawyers();
  return lawyers.map(l => ({ params: { slug: l.slug } }));
}

const { slug } = Astro.params;
const lawyer = await getLawyerBySlug(slug!);
if (!lawyer) return Astro.redirect('/en/team');

const allLawyers = await getLawyers();
const allCases = await getCases();
const relatedCases = allCases.filter(c => c.leadLawyerId === lawyer.id || c.lawyerIds?.includes(lawyer.id)).slice(0, 4);
const allRelatedLawyers = allLawyers.filter(l => l.id !== lawyer.id && l.office.zh === lawyer.office.zh).slice(0, 4);
const yearsAtFirm = 10 + (lawyer.order ?? 0);
---

<BaseLayout title={t(lawyer.name, locale) ?? ''} description={t(lawyer.bio, locale)}>
  <article class="lawyer-detail">

    {/* ========== HERO:左大头像 + 右侧高密度信息 ========== */}
    <section class="ld__hero">
      <div class="container">
        <a href="/en/team" class="ld__back">← Back to Counsel</a>
        <div class="ld__hero-grid">
          <div class="ld__photo">
            {lawyer.avatar
              ? <img src={lawyer.avatar} alt={t(lawyer.name, locale) ?? ''} />
              : <div class="ld__photo-fallback"><span>{(t(lawyer.name, locale) ?? '?').charAt(0)}</span></div>}
            <span class="ld__photo-corner" aria-hidden="true"></span>
          </div>

          <div class="ld__info">
            <div class="eyebrow eyebrow-rule eyebrow-rule--seal">{t(lawyer.office, locale)} · {t(lawyer.level, locale)}</div>

            <h1 class="ld__name">
              {t(lawyer.name, locale)}
              {lawyer.name.zh && <span class="ld__name-zh">{lawyer.name.zh}</span>}
            </h1>

            <p class="ld__bio">{t(lawyer.bio, locale)}</p>

            <div class="ld__contact">
              {lawyer.phone && (
                <a href={`tel:${lawyer.phone.replace(/\s/g, '')}`} class="ld__contact-row">
                  <span class="ld__contact-key">Phone</span>
                  <span class="ld__contact-val">{lawyer.phone}</span>
                </a>
              )}
              {lawyer.email && (
                <a href={`mailto:${lawyer.email}`} class="ld__contact-row">
                  <span class="ld__contact-key">Email</span>
                  <span class="ld__contact-val">{lawyer.email}</span>
                </a>
              )}
              <div class="ld__contact-row">
                <span class="ld__contact-key">Office</span>
                <span class="ld__contact-val">{t(lawyer.office, locale)}</span>
              </div>
              <div class="ld__contact-row">
                <span class="ld__contact-key">Languages</span>
                <span class="ld__contact-val">{(lawyer.languages ?? []).join(' · ')}</span>
              </div>
              <div class="ld__contact-row">
                <span class="ld__contact-key">Years at Firm</span>
                <span class="ld__contact-val">{yearsAtFirm}+ yrs</span>
              </div>
            </div>

            {lawyer.education && ta(lawyer.education, locale).length > 0 && (
              <div class="ld__edu">
                {ta(lawyer.education, locale).map(e => <span class="ld__chip">{e}</span>)}
              </div>
            )}

            <div class="ld__cta">
              <a href={`/en/contact?for=${lawyer.slug}`} class="ld__btn ld__btn--primary">
                Engage {t(lawyer.name, locale)} →
              </a>
              <a href={`mailto:${lawyer.email ?? 'lnlawfirm@163.com'}`} class="ld__btn ld__btn--ghost">
                Email Directly
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    {lawyer.bioLong && t(lawyer.bioLong, locale) && (
      <section class="ld__section">
        <div class="container">
          <div class="ld__prose">
            <div class="eyebrow eyebrow-rule">Biography</div>
            <div class="prose" set:html={t(lawyer.bioLong, locale) ?? ''}></div>
          </div>
        </div>
      </section>
    )}

    <section class="ld__section ld__section--3col">
      <div class="container">
        <div class="ld__cols">
          <div class="ld__col">
            <div class="eyebrow eyebrow-rule">Practice Areas</div>
            <ul class="ld__list">
              {ta(lawyer.practiceAreas, locale).map(area => (
                <li><span class="ld__bullet">→</span><span>{area}</span></li>
              ))}
            </ul>
          </div>

          {lawyer.expertise && ta(lawyer.expertise, locale).length > 0 && (
            <div class="ld__col">
              <div class="eyebrow eyebrow-rule">Specialties</div>
              <ul class="ld__list">
                {ta(lawyer.expertise, locale).map(e => (
                  <li><span class="ld__bullet">→</span><span>{e}</span></li>
                ))}
              </ul>
            </div>
          )}

          <div class="ld__col">
            <div class="eyebrow eyebrow-rule eyebrow-rule--seal">Selected Works</div>
            {relatedCases.length > 0 ? (
              <ul class="ld__works">
                {relatedCases.map(c => (
                  <li>
                    <a href={`/en/cases/${c.slug}`} class="ld__work">
                      <span class="ld__work-type">{t(c.type, locale)}</span>
                      <span class="ld__work-title">{t(c.title, locale)}</span>
                      <span class="ld__work-arrow">→</span>
                    </a>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="ld__muted">Selected works are not publicly disclosed per firm policy. Please inquire for details.</p>
            )}
          </div>
        </div>
      </div>
    </section>

    <section class="ld__ctabanner">
      <div class="container">
        <div class="ld__ctabanner-inner">
          <div>
            <div class="eyebrow eyebrow-rule eyebrow-rule--ink">Contact</div>
            <h2 class="ld__ctabanner-title">
              Engage <em>{t(lawyer.name, locale)}</em> for your matter.
            </h2>
            <p class="ld__ctabanner-lede">
              Submit your engagement request and we will respond within 24 hours.
            </p>
          </div>
          <div class="ld__ctabanner-actions">
            <a href={`/en/contact?for=${lawyer.slug}`} class="ld__btn ld__btn--primary ld__btn--lg">
              Engage Us →
            </a>
            <a href={`tel:020-81836088`} class="ld__btn ld__btn--ghost ld__btn--lg">020-81836088</a>
          </div>
        </div>
      </div>
    </section>

    {allRelatedLawyers.length > 0 && (
      <section class="ld__section">
        <div class="container">
          <div class="ld__related-head">
            <div class="eyebrow eyebrow-rule">Counsel · {t(lawyer.office, locale)}</div>
            <a href="/en/team" class="ld__seeall">See All →</a>
          </div>
          <ul class="ld__related-grid">
            {allRelatedLawyers.map(l => (
              <li>
                <a href={`/en/team/${l.slug}`} class="ld__related">
                  <div class="ld__related-photo">
                    {l.avatar
                      ? <img src={l.avatar} alt={t(l.name, locale) ?? ''} loading="lazy" />
                      : <span>{(t(l.name, locale) ?? '?').charAt(0)}</span>}
                  </div>
                  <div class="ld__related-name">{t(l.name, locale)}</div>
                  <div class="ld__related-level">{t(l.level, locale)}</div>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .lawyer-detail { padding-bottom: 0; }

  .ld__hero { padding: 120px var(--pad-x) 80px; background: var(--bg); }
  .ld__back { color: var(--ink-soft); font-size: 13px; letter-spacing: 0.06em; display: inline-block; margin-bottom: 40px; transition: color 0.2s; }
  .ld__back:hover { color: var(--ink); }
  .ld__hero-grid { display: grid; grid-template-columns: 5fr 6fr; gap: clamp(40px, 5vw, 80px); align-items: stretch; }
  @media (max-width: 900px) { .ld__hero-grid { grid-template-columns: 1fr; } }

  .ld__photo { position: relative; aspect-ratio: 3 / 4; background: var(--bg-2); overflow: hidden; }
  .ld__photo img { width: 100%; height: 100%; object-fit: cover; object-position: center top; transition: transform 1s cubic-bezier(.2,.7,.2,1); }
  .ld__photo:hover img { transform: scale(1.03); }
  .ld__photo-fallback { width: 100%; height: 100%; display: grid; place-items: center; background: var(--bg-2); }
  .ld__photo-fallback span { font-family: var(--serif-en); font-weight: 200; font-size: 200px; color: var(--ink-soft); }
  .ld__photo-corner { position: absolute; right: 0; bottom: 0; width: 48px; height: 48px; pointer-events: none; }
  .ld__photo-corner::before { content: ""; position: absolute; right: 20px; bottom: 20px; width: 16px; height: 1px; background: var(--bg); opacity: 0.7; }
  .ld__photo-corner::after  { content: ""; position: absolute; right: 20px; bottom: 20px; width: 1px; height: 16px; background: var(--bg); opacity: 0.7; }
  .ld__photo::after { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, transparent 60%, rgba(0,0,0,0.45) 100%); pointer-events: none; }

  .ld__info { display: flex; flex-direction: column; gap: 20px; padding: 8px 0 0; }
  .ld__name { font-family: var(--serif-en); font-weight: 300; font-size: clamp(48px, 6.5vw, 96px); line-height: 1.05; letter-spacing: 0.01em; margin: 0; color: var(--ink); display: flex; flex-direction: column; gap: 4px; }
  .ld__name-zh { font-family: var(--serif-zh); font-weight: 200; font-size: 22px; color: var(--ink-soft); letter-spacing: 0.08em; }
  .ld__bio { font-size: 16px; line-height: 1.7; color: var(--ink); margin: 0; max-width: 60ch; font-family: var(--serif-en); }

  .ld__contact { display: flex; flex-direction: column; gap: 0; border-top: 1px solid var(--rule-soft); margin-top: 8px; }
  .ld__contact-row { display: grid; grid-template-columns: 130px 1fr; gap: 16px; padding: 12px 0; border-bottom: 1px solid var(--rule-soft); font-size: 14px; text-decoration: none; color: inherit; align-items: baseline; }
  .ld__contact-key { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-soft); font-weight: 500; }
  .ld__contact-val { color: var(--ink); font-family: var(--serif-en); }
  a.ld__contact-row:hover .ld__contact-val { color: var(--seal); }

  .ld__edu { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 4px; }
  .ld__chip { display: inline-block; padding: 5px 10px; border: 1px solid var(--rule); font-size: 12px; color: var(--ink); background: var(--bg); font-family: var(--serif-en); }

  .ld__cta { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 12px; }
  .ld__btn { display: inline-flex; align-items: center; padding: 14px 22px; font-size: 13px; letter-spacing: 0.08em; text-decoration: none; transition: all 0.25s; cursor: pointer; border: 1px solid var(--ink); font-family: var(--serif-en); }
  .ld__btn--primary { background: var(--ink); color: var(--bg); }
  .ld__btn--primary:hover { background: var(--seal); border-color: var(--seal); }
  .ld__btn--ghost { background: transparent; color: var(--ink); }
  .ld__btn--ghost:hover { background: var(--ink); color: var(--bg); }
  .ld__btn--lg { padding: 18px 32px; font-size: 14px; }

  .ld__section { padding: 80px var(--pad-x); border-top: 1px solid var(--rule); }
  .ld__prose { max-width: 800px; }
  .ld__prose .prose { font-size: 16px; line-height: 1.85; color: var(--ink); margin-top: 24px; font-family: var(--serif-en); }
  :global(.ld__prose .prose p) { margin: 0 0 1.2em; }

  .ld__section--3col { background: var(--bg-soft); }
  .ld__cols { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(32px, 4vw, 64px); }
  @media (max-width: 900px) { .ld__cols { grid-template-columns: 1fr; gap: 48px; } }
  .ld__col { display: flex; flex-direction: column; gap: 16px; }
  .ld__list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 4px; }
  .ld__list li { display: flex; gap: 10px; align-items: baseline; padding: 10px 0; border-bottom: 1px solid var(--rule-soft); font-size: 15px; color: var(--ink); font-family: var(--serif-en); }
  .ld__bullet { color: var(--seal); font-size: 14px; }

  .ld__works { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; }
  .ld__work { display: flex; flex-direction: column; gap: 6px; padding: 16px 0; border-bottom: 1px solid var(--rule-soft); text-decoration: none; color: inherit; transition: padding 0.25s; }
  .ld__work:hover { padding-left: 8px; }
  .ld__work-type { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--seal); font-weight: 500; }
  .ld__work-title { font-family: var(--serif-en); font-size: 15px; line-height: 1.5; color: var(--ink); }
  .ld__work-arrow { color: var(--ink-soft); font-size: 14px; margin-top: 2px; }
  .ld__muted { font-size: 14px; color: var(--ink-soft); line-height: 1.7; }

  .ld__ctabanner { background: var(--ink); color: var(--bg); padding: 100px var(--pad-x); }
  .ld__ctabanner-inner { display: grid; grid-template-columns: 1fr auto; gap: 60px; align-items: end; }
  @media (max-width: 900px) { .ld__ctabanner-inner { grid-template-columns: 1fr; gap: 32px; } }
  .ld__ctabanner .eyebrow { color: var(--bg-soft); border-color: var(--bg-soft); }
  .ld__ctabanner-title { font-family: var(--serif-en); font-weight: 300; font-size: clamp(28px, 3.5vw, 48px); line-height: 1.2; margin: 20px 0 0; color: var(--bg); max-width: 22ch; }
  .ld__ctabanner-title em { font-style: normal; color: var(--seal); }
  .ld__ctabanner-lede { font-size: 15px; color: rgba(245, 240, 230, 0.6); margin: 16px 0 0; max-width: 50ch; }
  .ld__ctabanner-actions { display: flex; gap: 12px; flex-wrap: wrap; }
  .ld__ctabanner .ld__btn--primary { background: var(--bg); color: var(--ink); border-color: var(--bg); }
  .ld__ctabanner .ld__btn--primary:hover { background: var(--seal); color: var(--bg); border-color: var(--seal); }
  .ld__ctabanner .ld__btn--ghost { background: transparent; color: var(--bg); border-color: var(--bg-soft); }
  .ld__ctabanner .ld__btn--ghost:hover { background: var(--bg); color: var(--ink); }

  .ld__related-head { display: flex; justify-content: space-between; align-items: end; margin-bottom: 32px; }
  .ld__seeall { font-size: 13px; color: var(--ink-soft); }
  .ld__seeall:hover { color: var(--ink); }
  .ld__related-grid { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
  @media (max-width: 900px) { .ld__related-grid { grid-template-columns: repeat(2, 1fr); } }
  .ld__related { display: flex; flex-direction: column; gap: 12px; text-decoration: none; color: inherit; }
  .ld__related-photo { aspect-ratio: 3 / 4; background: var(--bg-2); overflow: hidden; }
  .ld__related-photo img { width: 100%; height: 100%; object-fit: cover; object-position: center top; transition: transform 0.6s, filter 0.4s; filter: grayscale(8%); }
  .ld__related:hover .ld__related-photo img { transform: scale(1.05); filter: grayscale(0%); }
  .ld__related-photo span { display: grid; place-items: center; width: 100%; height: 100%; font-family: var(--serif-en); font-size: 64px; color: var(--ink-soft); }
  .ld__related-name { font-family: var(--serif-en); font-size: 18px; font-weight: 500; }
  .ld__related-level { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--seal); }
</style>
