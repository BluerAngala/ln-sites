---
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageHero from '~/components/PageHero.astro';
import LawyerCard from '~/components/LawyerCard.astro';
import { getLawyers } from '~/lib/content';
import { t, DEFAULT_LOCALE, type Locale } from '~/i18n';

const locale: Locale = 'en' as const;
const lawyers = await getLawyers();
const partners = lawyers.filter(l => (t(l.level, locale) ?? '').toLowerCase().includes('partner') || t(l.level, locale)?.includes('合伙人'));
const others = lawyers.filter(l => !partners.includes(l));
---

<BaseLayout title={t({ zh: '专业人员', en: 'Counsel' }, locale)}>
  <PageHero
    eyebrow={t({ zh: 'Counsel · 律师', en: 'Counsel' }, locale)}
    title={t({ zh: '汇聚精英，<br/>注重专业与协作并进。', en: 'A Team Built on Depth<br/>and Collaboration.' }, locale)}
    lede={t({ zh: '以深度洞察与集体智慧，为客户提供全方位、高品质的法律服务。', en: 'Combining deep insight with collective wisdom.' }, locale)}
  />

  {partners.length > 0 && (
    <section class="section--tight" style="padding-top: 0;">
      <div class="container">
        <h2 class="eyebrow eyebrow-rule" style="font-size: 14px; margin-bottom: 32px;">{t({ zh: '合伙人 · Partners', en: 'Partners' }, locale)}</h2>
        <div class="grid grid--3">
          {partners.map(l => <LawyerCard lawyer={l} locale="en" />)}
        </div>
      </div>
    </section>
  )}

  {others.length > 0 && (
    <section class="section--tight">
      <div class="container">
        <h2 class="eyebrow eyebrow-rule" style="font-size: 14px; margin-bottom: 32px;">{t({ zh: '资深律师 · Senior Counsels', en: 'Senior Counsels' }, locale)}</h2>
        <div class="grid grid--3">
          {others.map(l => <LawyerCard lawyer={l} locale="en" />)}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
