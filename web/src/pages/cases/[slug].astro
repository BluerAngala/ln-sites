---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCases, getCaseBySlug, getLawyers } from '~/lib/content';
import { t, ta, DEFAULT_LOCALE, type Locale } from '~/i18n';

export async function getStaticPaths() {
  const cases = await getCases();
  const paths: any[] = [];
  for (const locale of ['zh', 'en'] as const) {
    for (const c of cases) {
      paths.push({ params: { slug: c.slug }, props: { caseSlug: c.slug, locale } });
    }
  }
  return paths;
}

const { caseSlug } = Astro.props as { caseSlug: string; locale: Locale };
const locale: Locale = Astro.url.pathname.startsWith('/en/') || Astro.url.pathname === '/en'
  ? 'en' : DEFAULT_LOCALE;
const c = await getCaseBySlug(caseSlug);
if (!c) return Astro.redirect(`/${locale}/cases`);

const allLawyers = await getLawyers();
const leadLawyer = c.leadLawyerId ? allLawyers.find(l => l.id === c.leadLawyerId) : undefined;
const otherLawyers = (c.lawyerIds ?? []).filter(id => id !== c.leadLawyerId)
  .map(id => allLawyers.find(l => l.id === id))
  .filter(Boolean) as typeof allLawyers;
---

<BaseLayout title={t(c.title, locale) ?? ''} description={t(c.summary, locale)}>
  <article class="case-detail">
    <div class="container">
      <a href={`/${locale}/cases`} class="back-link">← {t({ zh: '返回案例列表', en: 'Back to Works' }, locale)}</a>

      <header style="margin-top: 32px; border-bottom: 1px solid var(--rule); padding-bottom: 40px;">
        <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 16px;">
          <span class="tag tag--seal">{t(c.type, locale)}</span>
          <span class="tag">{t(c.industry, locale)}</span>
          <span class="tag">{c.year}</span>
          {t(c.practiceArea, locale) && <span class="tag">{t(c.practiceArea, locale)}</span>}
        </div>
        <h1 class="h1" style="font-size: clamp(36px, 5vw, 64px); margin: 0 0 24px;">{t(c.title, locale)}</h1>
        <p class="lede" style="max-width: 720px;">{t(c.summary, locale)}</p>
      </header>

      <div class="grid grid--2" style="gap: clamp(40px, 6vw, 100px); margin-top: 60px; align-items: start;">
        <div class="prose" set:html={t(c.content, locale) ?? ''}></div>

        <aside>
          {c.highlights && ta(c.highlights, locale).length > 0 && (
            <div class="case-highlights">
              <span class="eyebrow eyebrow-rule eyebrow-rule--seal">{t({ zh: '亮点', en: 'Highlights' }, locale)}</span>
              <ul style="margin-top: 16px; list-style: none; padding: 0;">
                {ta(c.highlights, locale).map(h => <li class="case-highlight">{h}</li>)}
              </ul>
            </div>
          )}

          <div style="margin-top: 40px;">
            <span class="eyebrow eyebrow-rule">{t({ zh: '主理律师', en: 'Lead Counsel' }, locale)}</span>
            {leadLawyer && (
              <a href={`/${locale}/team/${leadLawyer.slug}`} class="case-lawyer-link">
                <strong>{t(leadLawyer.name, locale)}</strong>
                <span class="muted"> · {t(leadLawyer.level, locale)}</span>
                <span class="arrow">→</span>
              </a>
            )}
          </div>

          {otherLawyers.length > 0 && (
            <div style="margin-top: 32px;">
              <span class="eyebrow eyebrow-rule">{t({ zh: '协办律师', en: 'Co-Counsel' }, locale)}</span>
              <ul style="margin-top: 16px;">
                {otherLawyers.map(l => (
                  <li style="padding: 8px 0; border-bottom: 1px solid var(--rule-soft);">
                    <a href={`/${locale}/team/${l.slug}`} style="display: flex; justify-content: space-between; align-items: center;">
                      <span><strong>{t(l.name, locale)}</strong> <span class="muted">· {t(l.level, locale)}</span></span>
                      <span class="arrow">→</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <div style="margin-top: 40px;">
            <a href={`/${locale}/contact`} class="btn btn--solid btn--full">{t({ zh: '就此咨询', en: 'Inquire' }, locale)} →</a>
          </div>
        </aside>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .back-link { color: var(--ink-soft); font-size: 14px; display: inline-block; margin-top: 100px; }
  .back-link:hover { color: var(--ink); }
  .case-highlight { padding: 14px 16px; background: var(--bg-2); border-left: 3px solid var(--seal); margin-bottom: 8px; font-size: 15px; }
  .case-lawyer-link { display: flex; justify-content: space-between; align-items: center; padding: 16px; background: var(--bg-soft); border: 1px solid var(--rule-soft); border-radius: var(--radius); margin-top: 12px; transition: border-color 0.2s; }
  .case-lawyer-link:hover { border-color: var(--ink); text-decoration: none; }
</style>
