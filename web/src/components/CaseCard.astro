---
/**
 * 业绩案例卡（首页/列表共用）
 * 表达结构：案情背景 → 律师介入 → 客户收获（让客户看到律师的"价值"）
 */
import type { CaseItem } from '~/lib/types';
import { t, DEFAULT_LOCALE, type Locale } from '~/i18n';

interface Props { case: CaseItem; locale?: Locale }
const locale: Locale = (Astro.props.locale ?? (Astro.currentLocale as Locale)) || DEFAULT_LOCALE;
const c = Astro.props.case;
---

<a class="case-card-link" href={`${locale === 'en' ? '/en' : ''}/cases/${c.slug}`}>
  <article class="case-card">
    <div class="case-card__head">
      <span class="case-card__type">{t(c.type, locale)}</span>
      <h3 class="case-card__title">{t(c.title, locale)}</h3>
    </div>

    <div class="case-card__block case-card__block--bg">
      <span class="case-card__label">案情 · Background</span>
      <p class="case-card__text">{t(c.background, locale)}</p>
    </div>

    <div class="case-card__block case-card__block--approach">
      <span class="case-card__label">律师介入 · Approach</span>
      <p class="case-card__text">{t(c.approach, locale)}</p>
    </div>

    <div class="case-card__block case-card__block--result">
      <span class="case-card__label">客户收获 · Result</span>
      <p class="case-card__text">{t(c.result, locale)}</p>
    </div>

    <div class="case-card__cta">查看详情 <span class="arrow">→</span></div>
  </article>
</a>

<style>
  .case-card-link { display: block; height: 100%; }
  .case-card-link:hover { text-decoration: none; }

  .case-card {
    display: flex; flex-direction: column;
    height: 100%;
    background: var(--bg);
    border: 1px solid var(--rule-soft);
    padding: 40px 36px 32px;
    transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
    position: relative;
  }
  .case-card-link:hover .case-card { border-color: var(--ink); transform: translateY(-3px); box-shadow: var(--shadow-2); }

  .case-card__head { margin-bottom: 28px; }
  .case-card__type {
    display: inline-block; padding: 5px 14px;
    font-size: 13px; letter-spacing: 0.16em;
    background: var(--seal); color: var(--bg);
    font-family: var(--serif-zh); font-weight: 500;
    margin-bottom: 18px;
  }
  .case-card__title {
    font-family: var(--serif-zh); font-weight: 500;
    font-size: 24px; line-height: 1.35; letter-spacing: 0.01em;
    margin: 0; color: var(--ink);
  }

  .case-card__block { padding: 16px 0; border-top: 1px solid var(--rule-soft); }
  .case-card__block--bg { border-top: 0; padding-top: 0; padding-bottom: 18px; }

  .case-card__label {
    display: block;
    font-family: var(--serif-en); font-size: 11px;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--ink-soft); margin-bottom: 8px;
  }
  .case-card__block--result .case-card__label { color: var(--seal); }
  .case-card__text {
    margin: 0; font-size: 15px; line-height: 1.85;
    color: var(--ink); font-weight: 400;
  }
  .case-card__block--result .case-card__text { color: var(--ink); font-weight: 500; }

  .case-card__cta {
    margin-top: auto; padding-top: 20px;
    font-size: 14px; font-weight: 500; letter-spacing: 0.06em;
    color: var(--seal);
    display: inline-flex; align-items: center; gap: 8px;
  }
  .case-card__cta .arrow { transition: transform 0.3s ease; }
  .case-card-link:hover .case-card__cta .arrow { transform: translateX(4px); }
</style>
