---
/**
 * 首页内容（同一份模板，locale 通过 prop 传入）
 *  - src/pages/index.astro          →  locale="zh"
 *  - src/pages/en/index.astro       →  locale="en"
 * 这样 Astro 5 i18n 在 prefixDefaultLocale:false 下能为两个 locale 各自生成首页
 */
import StatBar from '~/components/StatBar.astro';
import LawyerCarousel from '~/components/LawyerCarousel.astro';
import CaseCard from '~/components/CaseCard.astro';
import NewsCard from '~/components/NewsCard.astro';
import HonorWall from '~/components/HonorWall.astro';
import SectionHeader from '~/components/SectionHeader.astro';
import {
  getLawyers, getFeaturedCases, getLatestNews, getPractices, getHonors, getSiteConfig,
} from '~/lib/content';
import { t, type Locale } from '~/i18n';

interface Props { locale: Locale }
const locale = Astro.props.locale;

const config = await getSiteConfig();
const [lawyers, cases, news, practices, honors] = await Promise.all([
  getLawyers(),
  getFeaturedCases(6),
  getLatestNews(6),
  getPractices(),
  getHonors(),
]);
---

<section class="hero">
  <div class="hero__bg" aria-hidden="true">
    <img src="/img/hero/hero-team.jpg" alt="" class="hero__img" />
    <div class="hero__overlay"></div>
    <div class="hero__spotlight" data-hero-spotlight></div>
  </div>
  <div class="hero__inner">
    <div class="hero__kicker">
      <span>{t(config.heroKicker, locale)}</span>
      <span>·</span>
      <span>{t(config.heroBadge, locale)}</span>
    </div>
    <h1 class="hero__title">
      <span class="hero__title-zh" set:html={(t(config.heroTitle, locale) ?? '').replace(/\n/g, '<br/>')}></span>
      <span class="hero__title-en">{t(config.heroSubtitle, locale)}</span>
    </h1>
    <p class="hero__lede" set:html={(t(config.heroLede, locale) ?? '').replace(/\n/g, '<br/>')}></p>
    <div class="hero__cta">
      <a href={`${locale === 'en' ? '/en' : ''}/about`} class="hero__btn hero__btn--primary">
        {t({ zh: '走进岭南', en: 'About Us' }, locale)} <span class="arrow">→</span>
      </a>
      <a href={`${locale === 'en' ? '/en' : ''}/contact`} class="hero__btn hero__btn--ghost">
        {t({ zh: '委托咨询', en: 'Engage Us' }, locale)} <span class="arrow">→</span>
      </a>
    </div>
    <a href="#stats" class="hero__scroll" aria-label="Scroll">
      <span>SCROLL</span>
      <svg viewBox="0 0 12 20" fill="none">
        <rect x="0.5" y="0.5" width="11" height="19" rx="5.5" stroke="currentColor" stroke-opacity="0.6"/>
        <circle cx="6" cy="6" r="1.5" fill="currentColor">
          <animate attributeName="cy" values="6;14;6" dur="2s" repeatCount="indefinite"/>
        </circle>
      </svg>
    </a>
  </div>
</section>

<div id="stats"><StatBar /></div>

<section class="section about-section">
  <div class="container">
    <div class="about-header">
      <SectionHeader
        eyebrow={{ zh: '关于', en: 'About' }}
        title={{ zh: '四十载深耕，专业铸就信赖。', en: 'Forty Years of Practice. A Century of Trust.' }}
        align="center"
        locale={locale}
      />
    </div>
    <div class="grid about-grid">
      <div class="about-visual">
        <img src="/img/hero/hero-books.jpg" alt="Justice" class="about-visual__img" />
        <div class="about-visual__caption">Justice · Equity · Trust</div>
      </div>
      <div class="about-content">
        <blockquote class="about-quote">
          <p>{t(config.aboutQuote, locale)}</p>
          <footer>— {t(config.aboutQuoteAttr, locale)}</footer>
        </blockquote>
        <div class="prose" set:html={t(config.aboutBody, locale) ?? ''}></div>
        <div style="text-align: right; margin-top: 32px;">
          <a href={`${locale === 'en' ? '/en' : ''}/about`} class="btn btn--ghost">{t({ zh: '了解更多', en: 'Learn More' }, locale)} →</a>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section--tight practices-section">
  <div class="container">
    <div style="text-align: center;">
      <SectionHeader
        eyebrow={{ zh: '业务领域', en: 'Practices' }}
        title={{ zh: '八大方舟，一以贯之', en: 'Eight Pillars. One Standard.' }}
        align="center"
        locale={locale}
      />
      <p class="lede muted" style="max-width: 640px; margin: 0 auto;">{t({ zh: '专注于法律服务的精进与创新，持续完善多元业务体系。', en: 'Focused on the refinement and innovation of legal services, we continuously improve our multi-disciplinary practice.' }, locale)}</p>
      <p class="lede muted" style="max-width: 640px; margin: 12px auto 0;">{t({ zh: '为客户提供前沿、专业的法律解决方案。', en: 'To deliver forward-looking and professional solutions to every client.' }, locale)}</p>
    </div>
    <div class="practices-grid">
      {practices.map((p, i) => (
        <a href={`${locale === 'en' ? '/en' : ''}/practice#${p.id}`} class="practice-card" data-idx={i + 1}>
          <div class="practice-card__main">
            <div class="practice-card__head">
              <div class="practice-card__num">{String(i + 1).padStart(2, '0')}</div>
              <h3 class="practice-card__name">{t(p.name, locale)}</h3>
            </div>
            <p class="practice-card__nameEn">{p.nameEn}</p>
            <p class="practice-card__desc">{t(p.description, locale)}</p>
          </div>
          {p.caseCount != null && (
            <div class="practice-card__count">
              <span class="practice-card__count-num">{p.caseCount}</span>
              <span class="practice-card__count-label">+ {t({ zh: '案例', en: 'Cases' }, locale)}</span>
            </div>
          )}
        </a>
      ))}
    </div>
  </div>
</section>

<section class="section--tight" style="padding: clamp(40px, 5vw, 80px) 0 0;">
  <LawyerCarousel
    lawyers={lawyers}
    title={{ zh: '执业律师', en: 'Attorneys at Law' }}
    eyebrow={{ zh: '专业人员', en: 'Counsel' }}
    lede={{ zh: '汇聚精英团队，注重专业与协作并进。', en: 'A team of senior practitioners combining deep insight with collective wisdom.' }}
    locale={locale}
  />
</section>

<section class="section">
  <div class="container">
    <SectionHeader
      eyebrow={{ zh: '荣誉', en: 'Honors' }}
      title={{ zh: '荣誉与资质', en: 'Honors & Credentials' }}
      align="center"
      locale={locale}
    />
    <div style="text-align: right; margin-bottom: 32px;">
      <a href={`${locale === 'en' ? '/en' : ''}/honors`} class="btn btn--ghost">{t({ zh: '全部荣誉', en: 'All Honors' }, locale)} →</a>
    </div>
    <HonorWall honors={honors} locale={locale} />
  </div>
</section>

<section class="section" style="background: var(--bg-2);">
  <div class="container">
    <SectionHeader
      eyebrow={{ zh: '资讯', en: 'Insight' }}
      title={{ zh: '所内动态 · 行业观察', en: 'Firm News & Industry View' }}
      align="center"
      locale={locale}
    />
    <div style="text-align: right; margin-bottom: 40px;">
      <a href={`${locale === 'en' ? '/en' : ''}/news`} class="btn btn--ghost">{t({ zh: '全部资讯', en: 'All News' }, locale)} →</a>
    </div>
    <div class="grid grid--3">{news.map(n => <NewsCard news={n} locale={locale} />)}</div>
  </div>
</section>

<section class="section--ink section" style="text-align: center; padding: clamp(80px, 12vw, 160px) var(--pad-x);">
  <div class="container" style="max-width: 720px;">
    <h2 class="h2" style="margin: 0 0 16px; font-size: clamp(28px, 4vw, 48px); white-space: nowrap;">{t(config.tagline, locale)}</h2>
    <p style="color: rgba(245,240,230,0.7); margin-bottom: 40px; font-size: 20px; line-height: 1.8;">{t(config.tagline2, locale)}</p>
    <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
      <a href={`${locale === 'en' ? '/en' : ''}/contact`} class="btn btn--seal">{t({ zh: '发起委托', en: 'Engage Us' }, locale)} →</a>
      <a href={`tel:${config.contactPhone.replace(/\s/g, '')}`} class="btn btn--ghost" style="color: var(--bg); border-color: rgba(245,240,230,0.5);">{config.contactPhone}</a>
    </div>
  </div>
</section>

<style>
  .hero { position: relative; min-height: 100vh; overflow: hidden; display: flex; align-items: center; padding: 80px var(--pad-x) 120px; --mx: 50%; --my: 35%; }
  .hero__bg { position: absolute; inset: 0; z-index: 0; }
  .hero__img { width: 100%; height: 100%; object-fit: cover; object-position: center 30%; filter: brightness(0.78) saturate(0.95); }
  .hero__overlay { position: absolute; inset: 0; background:
    linear-gradient(180deg, rgba(10,8,6,0.35) 0%, rgba(10,8,6,0.2) 30%, rgba(10,8,6,0.55) 100%),
    radial-gradient(ellipse 80% 85% at center 45%, rgba(10,8,6,0.18) 0%, rgba(10,8,6,0.5) 100%);
  }
  .hero__spotlight { position: absolute; inset: 0; pointer-events: none; opacity: 0; transition: opacity 0.5s ease; background: radial-gradient(circle 480px at var(--mx) var(--my), transparent 0%, transparent 22%, rgba(10,8,6,0.5) 100%); }
  @media (hover: hover) { .hero:hover .hero__spotlight { opacity: 1; } }
  .hero__inner { position: relative; z-index: 1; max-width: var(--max); margin: 0 auto; width: 100%; color: var(--bg); text-align: center; display: flex; flex-direction: column; align-items: center; text-shadow: 0 2px 18px rgba(0,0,0,0.45), 0 1px 2px rgba(0,0,0,0.4); }
  .hero__kicker { display: inline-flex; align-items: center; gap: 16px; font-family: var(--serif-en); font-size: 12px; letter-spacing: 0.32em; text-transform: uppercase; color: rgba(245, 240, 230, 0.9); margin-bottom: 24px; padding: 8px 24px; border: 1px solid rgba(245, 240, 230, 0.4); border-radius: 999px; }
  .hero__title { margin: 0 0 16px; }
  .hero__title-zh { display: block; font-family: var(--serif-zh); font-weight: 500; font-size: clamp(36px, 5.4vw, 68px); line-height: 1.1; letter-spacing: 0.04em; color: var(--bg); }
  :global(html[lang="en"]) .hero__title-zh { font-family: var(--serif-en); font-weight: 400; font-style: italic; }
  .hero__title-en { display: block; font-family: var(--serif-en); font-style: italic; font-weight: 300; font-size: clamp(14px, 1.6vw, 20px); letter-spacing: 0.16em; color: rgba(245, 240, 230, 0.85); margin-top: 8px; }
  .hero__lede { max-width: 640px; font-size: 16px; line-height: 1.8; color: rgba(245, 240, 230, 0.95); font-weight: 400; margin: 0 0 16px; }
  .hero__cta { display: flex; gap: 64px; flex-wrap: wrap; justify-content: center; margin-bottom: 16px; }
  .hero__btn {
    position: relative; display: inline-flex; align-items: center; gap: 12px;
    padding: 18px 34px; font-family: var(--serif-zh); font-size: 15px; font-weight: 500;
    letter-spacing: 0.12em; border-radius: 2px; transition: all 0.3s; text-decoration: none;
  }
  .hero__btn .arrow { transition: transform 0.3s ease; display: inline-block; }
  .hero__btn:hover .arrow { transform: translateX(4px); }

  /* 印章风主按钮：seal 红 + 内框白线，hover 时内框向内收紧（按印感） */
  .hero__btn--primary { background: var(--seal); color: var(--bg); border: 1px solid var(--seal); }
  .hero__btn--primary::before {
    content: ""; position: absolute; inset: 5px;
    border: 1px solid rgba(245, 240, 230, 0.55);
    pointer-events: none; transition: inset 0.3s ease, border-color 0.3s ease;
  }
  .hero__btn--primary:hover { background: var(--seal-deep); transform: translateY(-1px); }
  .hero__btn--primary:hover::before { inset: 7px; border-color: rgba(245, 240, 230, 0.8); }

  /* 次按钮：hairline 极简 */
  .hero__btn--ghost {
    background: transparent; color: var(--bg);
    border: 1px solid rgba(245, 240, 230, 0.5);
  }
  .hero__btn--ghost:hover {
    background: rgba(245, 240, 230, 0.08);
    border-color: var(--bg);
  }

  .hero__scroll {
    position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%);
    z-index: 3;
    display: flex; flex-direction: column; align-items: center; gap: 12px;
    color: rgba(245, 240, 230, 0.9); font-family: var(--serif-en); font-size: 12px;
    letter-spacing: 0.36em; transition: color 0.3s;
  }
  .hero__scroll svg { opacity: 0.9; transition: opacity 0.3s; width: 18px; height: 32px; }
  .hero__scroll:hover { color: var(--bg); }
  .hero__scroll:hover svg { opacity: 1; }
  .hero__scroll:hover { color: var(--bg); }
  @media (max-width: 700px) { .hero { min-height: 80vh; } }

  .about-section { background: var(--bg-soft); padding-top: clamp(40px, 5vw, 72px); }
  .about-header { margin-bottom: 56px; }
  .about-grid { gap: clamp(40px, 6vw, 100px); align-items: center; grid-template-columns: 1fr 2fr; }
  @media (max-width: 900px) { .about-grid { grid-template-columns: 1fr; } }
  .about-visual { position: relative; aspect-ratio: 4/5; max-width: 380px; background: var(--bg-2); border-radius: 4px; overflow: hidden; }
  .about-visual__img { width: 100%; height: 100%; object-fit: cover; }
  .about-visual__caption { position: absolute; bottom: 20px; left: 20px; right: 20px; font-family: var(--serif-en); font-size: 12px; letter-spacing: 0.4em; color: var(--bg); text-transform: uppercase; text-align: center; mix-blend-mode: difference; opacity: 0.7; }
  .about-quote { margin: 24px 0 32px; padding: 0 0 0 24px; border-left: 2px solid var(--seal); font-family: var(--serif-en); font-style: italic; color: var(--ink-soft); }
  .about-quote p { font-size: 19px; line-height: 1.6; margin: 0 0 12px; }
  .about-quote footer { font-family: var(--serif-en); font-style: normal; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; }

  /* Practices — 杂志大卡：2 列 × 4 行；[大编号] [业务名+描述] [案例数大数字] */
  .practices-grid { display: grid; grid-template-columns: repeat(2, 1fr); }
  .practices-grid > .practice-card { border-top: 1px solid var(--rule); }
  .practices-grid > .practice-card:nth-child(odd)  { border-right: 1px solid var(--rule); }
  .practices-grid > .practice-card:nth-child(even) { border-right: 0; }
  .practices-grid > .practice-card:nth-last-child(-n+2) { border-bottom: 1px solid var(--rule); }
  @media (max-width: 900px) {
    .practices-grid { grid-template-columns: 1fr; }
    .practices-grid > .practice-card { border-right: 0 !important; }
  }

  .practice-card {
    position: relative; display: grid;
    grid-template-columns: 1fr 110px;
    gap: 40px; align-items: center;
    padding: 44px 40px; text-decoration: none; color: inherit;
    transition: background 0.3s ease;
  }
  .practice-card:hover { background: var(--bg-2); }

  .practice-card__main { display: flex; flex-direction: column; gap: 14px; min-width: 0; }

  .practice-card__head { display: flex; align-items: center; gap: 18px; flex-wrap: nowrap; }
  .practice-card__num {
    font-family: var(--serif-en); font-size: 48px; font-weight: 200; line-height: 1;
    color: var(--seal); opacity: 0.55; letter-spacing: -0.02em;
    flex-shrink: 0;
    transition: opacity 0.3s ease;
  }
  .practice-card:hover .practice-card__num { opacity: 1; }

  .practice-card__name {
    font-family: var(--serif-zh); font-weight: 500; font-size: 26px; line-height: 1.25;
    margin: 0; letter-spacing: 0.01em;
    text-wrap: balance;
    min-width: 0; flex: 1;
  }
  :global(html[lang="en"]) .practice-card__name { font-family: var(--serif-en); font-weight: 400; font-size: 24px; }
  .practice-card__nameEn {
    font-family: var(--serif-en); font-size: 11px; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--ink-soft); margin: -4px 0 0;
  }
  .practice-card__desc {
    font-size: 14px; line-height: 1.85; color: var(--ink-soft); margin: 0;
  }

  .practice-card__count {
    display: flex; flex-direction: column; align-items: flex-end;
    font-family: var(--serif-en); gap: 10px;
    text-align: right; align-self: center;
  }
  .practice-card__count-num {
    font-size: 52px; font-weight: 200; line-height: 1;
    color: var(--seal); letter-spacing: -0.02em;
  }
  .practice-card__count-label {
    font-size: 16px; color: var(--ink);
    font-weight: 500; letter-spacing: 0.12em;
  }

  .section--ink .lawyer-tile { background: rgba(245, 240, 230, 0.05); border-color: rgba(245, 240, 230, 0.12); }
  .section--ink .lawyer-tile:hover { border-color: var(--bg); background: rgba(245, 240, 230, 0.08); }
  .section--ink .lawyer-tile__name { color: var(--bg); }
  .section--ink .lawyer-tile__name-en { color: rgba(245, 240, 230, 0.6); }
  .section--ink .lawyer-tile__title { color: rgba(245, 240, 230, 0.9); }
  .section--ink .lawyer-tile__excerpt { color: rgba(245, 240, 230, 0.7); }
  .section--ink .lawyer-tile__avatar { background: rgba(245, 240, 230, 0.08); color: rgba(245, 240, 230, 0.7); border-color: rgba(245, 240, 230, 0.12); }
  .section--ink .lawyer-tile__cta { color: rgba(245, 240, 230, 0.9); }
  .section--ink .tag { background: rgba(245, 240, 230, 0.08); color: rgba(245, 240, 230, 0.85); border-color: rgba(245, 240, 230, 0.15); }
  .section--ink .lc__btn { background: transparent; color: rgba(245, 240, 230, 0.7); border-color: rgba(245, 240, 230, 0.2); }
  .section--ink .lc__btn:hover { background: var(--bg); color: var(--ink); border-color: var(--bg); }
  .section--ink .h2 { color: var(--bg); }
  .section--ink .eyebrow-rule { color: rgba(245, 240, 230, 0.7); }
  .section--ink .eyebrow-rule::before, .section--ink .eyebrow-rule::after { background: rgba(245, 240, 230, 0.3); }
  .section--ink .lede { color: rgba(245, 240, 230, 0.7); }
  .section--ink .muted { color: rgba(245, 240, 230, 0.6); }
</style>

<script>
  const hero = document.querySelector<HTMLElement>('.hero');
  if (hero && window.matchMedia('(hover: hover)').matches) {
    let raf = 0;
    hero.addEventListener('mousemove', (e) => {
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(() => {
        const r = hero.getBoundingClientRect();
        const x = ((e.clientX - r.left) / r.width) * 100;
        const y = ((e.clientY - r.top) / r.height) * 100;
        hero.style.setProperty('--mx', x.toFixed(2) + '%');
        hero.style.setProperty('--my', y.toFixed(2) + '%');
      });
    });
  }
</script>
