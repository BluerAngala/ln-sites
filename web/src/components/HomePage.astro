---
/**
 * 首页内容（同一份模板，locale 通过 prop 传入）
 *  - src/pages/index.astro          →  locale="zh"
 *  - src/pages/en/index.astro       →  locale="en"
 * 这样 Astro 5 i18n 在 prefixDefaultLocale:false 下能为两个 locale 各自生成首页
 */
import StatBar from '~/components/StatBar.astro';
import LawyerCarousel from '~/components/LawyerCarousel.astro';
import CaseCard from '~/components/CaseCard.astro';
import NewsCard from '~/components/NewsCard.astro';
import {
  getLawyers, getFeaturedCases, getLatestNews, getPractices, getSiteConfig,
} from '~/lib/content';
import { t, type Locale } from '~/i18n';

interface Props { locale: Locale }
const locale = Astro.props.locale;

const config = await getSiteConfig();
const [lawyers, cases, news, practices] = await Promise.all([
  getLawyers(),
  getFeaturedCases(3),
  getLatestNews(3),
  getPractices(),
]);
---

<section class="hero">
  <div class="hero__bg" aria-hidden="true">
    <img src="/img/hero/hero-team.jpg" alt="" class="hero__img" />
    <div class="hero__overlay"></div>
  </div>
  <div class="hero__inner">
    <div class="hero__kicker">
      <span>{t(config.heroKicker, locale)}</span>
      <span>·</span>
      <span>{t(config.heroBadge, locale)}</span>
    </div>
    <h1 class="hero__title">
      <span class="hero__title-zh" set:html={(t(config.heroTitle, locale) ?? '').replace(/\n/g, '<br/>')}></span>
      <span class="hero__title-en">{t(config.heroSubtitle, locale)}</span>
    </h1>
    <p class="hero__lede" set:html={(t(config.heroLede, locale) ?? '').replace(/\n/g, '<br/>')}></p>
    <div class="hero__cta">
      <a href={`${locale === 'en' ? '/en' : ''}/contact`} class="hero__btn hero__btn--primary">
        {t({ zh: '委托咨询', en: 'Engage Us' }, locale)} <span class="arrow">→</span>
      </a>
      <a href={`${locale === 'en' ? '/en' : ''}/about`} class="hero__btn hero__btn--ghost">{t({ zh: '走进岭南 / About Us', en: 'Learn More' }, locale)}</a>
    </div>
    <a href="#stats" class="hero__scroll" aria-label="Scroll">
      <span>SCROLL</span>
      <svg width="12" height="20" viewBox="0 0 12 20" fill="none">
        <rect x="0.5" y="0.5" width="11" height="19" rx="5.5" stroke="currentColor" stroke-opacity="0.6"/>
        <circle cx="6" cy="6" r="1.5" fill="currentColor">
          <animate attributeName="cy" values="6;14;6" dur="2s" repeatCount="indefinite"/>
        </circle>
      </svg>
    </a>
  </div>
</section>

<div id="stats"><StatBar /></div>

<section class="section about-section">
  <div class="container">
    <div class="grid grid--2 about-grid">
      <div class="about-visual">
        <img src="/img/hero/hero-books.jpg" alt="Justice" class="about-visual__img" />
        <div class="about-visual__caption">Justice · Equity · Trust</div>
      </div>
      <div class="about-content">
        <span class="eyebrow eyebrow-rule eyebrow-rule--seal">About</span>
        <h2 class="h2" style="margin-top: 16px;">{t({ zh: '四十载深耕，专业铸就信赖。', en: 'Forty Years of Practice. A Century of Trust.' }, locale)}</h2>
        <blockquote class="about-quote">
          <p>{t(config.aboutQuote, locale)}</p>
          <footer>— {t(config.aboutQuoteAttr, locale)}</footer>
        </blockquote>
        <div class="prose" set:html={t(config.aboutBody, locale) ?? ''}></div>
        <a href={`${locale === 'en' ? '/en' : ''}/about`} class="btn btn--ghost" style="margin-top: 24px;">{t({ zh: '了解更多', en: 'Learn More' }, locale)} →</a>
      </div>
    </div>
  </div>
</section>

<section class="section--tight practices-section">
  <div class="container">
    <div style="text-align: center; margin-bottom: 80px;">
      <span class="eyebrow eyebrow-rule eyebrow-rule--seal">{t({ zh: '业务领域', en: 'Practices' }, locale)}</span>
      <h2 class="h2" style="margin: 24px 0 16px;">{t({ zh: '八大方舟，一以贯之', en: 'Eight Pillars. One Standard.' }, locale)}</h2>
      <p class="lede muted" style="max-width: 640px; margin: 0 auto;">{t({ zh: '专注于法律服务的精进与创新，持续完善多元业务体系，为客户提供前沿、专业的法律解决方案。', en: 'Focused on the refinement and innovation of legal services, we continuously improve our multi-disciplinary practice to deliver forward-looking and professional solutions.' }, locale)}</p>
    </div>
    <div class="grid grid--4">
      {practices.map((p, i) => (
        <a href={`${locale === 'en' ? '/en' : ''}/practice#${p.id}`} class="practice-card" data-idx={i + 1}>
          <div class="practice-card__num">{String(i + 1).padStart(2, '0')}</div>
          <div class="practice-card__name">{t(p.name, locale)}</div>
          <div class="practice-card__nameEn">{p.nameEn}</div>
          <p class="practice-card__desc">{t(p.description, locale)}</p>
          {p.caseCount != null && (
            <div class="practice-card__count">
              <span><strong>{p.caseCount}</strong><em>+</em> {t({ zh: '案例', en: 'Cases' }, locale)}</span>
            </div>
          )}
          <div class="practice-card__arrow">→</div>
        </a>
      ))}
    </div>
  </div>
</section>

<section class="section--ink" style="padding: clamp(60px, 8vw, 120px) 0;">
  <LawyerCarousel
    lawyers={lawyers}
    title={t({ zh: '执业律师', en: 'Attorneys at Law' }, locale)}
    eyebrow={t({ zh: 'Counsel · 专业人员', en: 'Counsel' }, locale)}
    lede={t({ zh: '汇聚精英团队，注重专业与协作并进。', en: 'A team of senior practitioners combining deep insight with collective wisdom.' }, locale)}
    locale={locale}
  />
</section>

<section class="section">
  <div class="container">
    <div style="display: flex; justify-content: space-between; align-items: end; flex-wrap: wrap; gap: 24px; margin-bottom: 60px;">
      <div>
        <span class="eyebrow eyebrow-rule eyebrow-rule--seal">{t({ zh: '业绩', en: 'Works' }, locale)}</span>
        <h2 class="h2" style="margin: 24px 0 0;">{t({ zh: '近期代表性案例', en: 'Selected Representations' }, locale)}</h2>
      </div>
      <a href={`${locale === 'en' ? '/en' : ''}/cases`} class="btn btn--ghost">{t({ zh: '全部案例', en: 'All Works' }, locale)} →</a>
    </div>
    <div class="grid grid--3">{cases.map(c => <CaseCard case={c} locale={locale} />)}</div>
  </div>
</section>

<section class="section" style="background: var(--bg-2);">
  <div class="container">
    <div style="display: flex; justify-content: space-between; align-items: end; flex-wrap: wrap; gap: 24px; margin-bottom: 60px;">
      <div>
        <span class="eyebrow eyebrow-rule">{t({ zh: '资讯', en: 'Insight' }, locale)}</span>
        <h2 class="h2" style="margin: 24px 0 0;">{t({ zh: '所内动态 · 行业观察', en: 'Firm News & Industry View' }, locale)}</h2>
      </div>
      <a href={`${locale === 'en' ? '/en' : ''}/news`} class="btn btn--ghost">{t({ zh: '全部资讯', en: 'All News' }, locale)} →</a>
    </div>
    <div class="grid grid--3">{news.map(n => <NewsCard news={n} locale={locale} />)}</div>
  </div>
</section>

<section class="section--ink section" style="text-align: center; padding: clamp(80px, 12vw, 160px) var(--pad-x);">
  <div class="container" style="max-width: 720px;">
    <h2 class="h2" style="margin: 0 0 16px;">{t(config.tagline, locale)}</h2>
    <p class="lede" style="color: rgba(245,240,230,0.7); margin-bottom: 40px;">{t(config.tagline2, locale)}</p>
    <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
      <a href={`${locale === 'en' ? '/en' : ''}/contact`} class="btn btn--seal">{t({ zh: '发起委托', en: 'Engage Us' }, locale)} →</a>
      <a href={`tel:${config.contactPhone.replace(/\s/g, '')}`} class="btn btn--ghost" style="color: var(--bg); border-color: rgba(245,240,230,0.5);">{config.contactPhone}</a>
    </div>
  </div>
</section>

<style>
  .hero { position: relative; min-height: 92vh; overflow: hidden; display: flex; align-items: center; padding: 120px var(--pad-x) 80px; }
  .hero__bg { position: absolute; inset: 0; z-index: 0; }
  .hero__img { width: 100%; height: 100%; object-fit: cover; object-position: center 30%; }
  .hero__overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,0.35) 0%, rgba(0,0,0,0.55) 100%), radial-gradient(ellipse at center, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.6) 100%); }
  .hero__inner { position: relative; z-index: 1; max-width: var(--max); margin: 0 auto; width: 100%; color: var(--bg); text-align: center; display: flex; flex-direction: column; align-items: center; }
  .hero__kicker { display: inline-flex; align-items: center; gap: 16px; font-family: var(--serif-en); font-size: 12px; letter-spacing: 0.32em; text-transform: uppercase; color: rgba(245, 240, 230, 0.75); margin-bottom: 32px; padding: 8px 24px; border: 1px solid rgba(245, 240, 230, 0.25); border-radius: 999px; }
  .hero__title { margin: 0 0 24px; }
  .hero__title-zh { display: block; font-family: var(--serif-zh); font-weight: 200; font-size: clamp(40px, 6vw, 80px); line-height: 1.1; letter-spacing: 0.04em; color: var(--bg); }
  :global(html[lang="en"]) .hero__title-zh { font-family: var(--serif-en); font-weight: 300; font-style: italic; }
  .hero__title-en { display: block; font-family: var(--serif-en); font-style: italic; font-weight: 300; font-size: clamp(14px, 1.6vw, 20px); letter-spacing: 0.16em; color: rgba(245, 240, 230, 0.7); margin-top: 12px; }
  .hero__lede { max-width: 640px; font-size: 17px; line-height: 1.95; color: rgba(245, 240, 230, 0.85); font-weight: 300; margin: 0 0 40px; }
  .hero__cta { display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; }
  .hero__btn { display: inline-flex; align-items: center; gap: 10px; padding: 16px 32px; font-family: var(--serif-zh); font-size: 15px; font-weight: 500; letter-spacing: 0.08em; border-radius: 2px; transition: all 0.3s; }
  .hero__btn--primary { background: var(--bg); color: var(--ink); }
  .hero__btn--primary:hover { background: var(--seal); color: var(--bg); }
  .hero__btn--ghost { background: transparent; color: var(--bg); border: 1px solid rgba(245, 240, 230, 0.5); }
  .hero__btn--ghost:hover { background: rgba(245, 240, 230, 0.1); border-color: var(--bg); }
  .hero__scroll { position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 8px; color: rgba(245, 240, 230, 0.6); font-family: var(--serif-en); font-size: 10px; letter-spacing: 0.3em; transition: color 0.3s; }
  .hero__scroll:hover { color: var(--bg); }
  @media (max-width: 700px) { .hero { min-height: 80vh; } }

  .about-section { background: var(--bg-soft); }
  .about-grid { gap: clamp(40px, 6vw, 100px); align-items: center; }
  .about-visual { position: relative; aspect-ratio: 4/5; max-width: 480px; background: var(--bg-2); border-radius: 4px; overflow: hidden; }
  .about-visual__img { width: 100%; height: 100%; object-fit: cover; }
  .about-visual__caption { position: absolute; bottom: 20px; left: 20px; right: 20px; font-family: var(--serif-en); font-size: 12px; letter-spacing: 0.4em; color: var(--bg); text-transform: uppercase; text-align: center; mix-blend-mode: difference; opacity: 0.7; }
  .about-quote { margin: 24px 0 32px; padding: 0 0 0 24px; border-left: 2px solid var(--seal); font-family: var(--serif-en); font-style: italic; color: var(--ink-soft); }
  .about-quote p { font-size: 19px; line-height: 1.6; margin: 0 0 12px; }
  .about-quote footer { font-family: var(--serif-en); font-style: normal; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; }

  .practice-card { position: relative; display: block; padding: 32px 0; border-top: 1px solid var(--rule); transition: all 0.3s; }
  .practice-card:hover { border-top-color: var(--seal); padding-left: 12px; text-decoration: none; }
  .practice-card__num { font-family: var(--serif-en); font-size: 11px; letter-spacing: 0.2em; color: var(--ink-soft); margin-bottom: 16px; }
  .practice-card__name { font-family: var(--serif-zh); font-weight: 500; font-size: 22px; margin-bottom: 4px; }
  :global(html[lang="en"]) .practice-card__name { font-family: var(--serif-en); font-weight: 400; }
  .practice-card__nameEn { font-family: var(--serif-en); font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-soft); margin-bottom: 12px; }
  .practice-card__desc { font-size: 13px; line-height: 1.7; color: var(--ink-soft); margin: 0 0 12px; }
  .practice-card__count { font-family: var(--serif-en); color: var(--seal); font-size: 13px; }
  .practice-card__count strong { font-size: 24px; font-weight: 300; margin-right: 4px; }
  .practice-card__count em { font-style: normal; color: var(--ink-soft); }
  .practice-card__arrow { position: absolute; right: 0; top: 32px; opacity: 0; transition: opacity 0.3s, transform 0.3s; font-size: 20px; color: var(--seal); }
  .practice-card:hover .practice-card__arrow { opacity: 1; transform: translateX(4px); }

  .section--ink .lawyer-tile { background: rgba(245, 240, 230, 0.05); border-color: rgba(245, 240, 230, 0.12); }
  .section--ink .lawyer-tile:hover { border-color: var(--bg); background: rgba(245, 240, 230, 0.08); }
  .section--ink .lawyer-tile__name { color: var(--bg); }
  .section--ink .lawyer-tile__name-en { color: rgba(245, 240, 230, 0.6); }
  .section--ink .lawyer-tile__title { color: rgba(245, 240, 230, 0.9); }
  .section--ink .lawyer-tile__excerpt { color: rgba(245, 240, 230, 0.7); }
  .section--ink .lawyer-tile__avatar { background: rgba(245, 240, 230, 0.08); color: rgba(245, 240, 230, 0.7); border-color: rgba(245, 240, 230, 0.12); }
  .section--ink .lawyer-tile__cta { color: rgba(245, 240, 230, 0.9); }
  .section--ink .tag { background: rgba(245, 240, 230, 0.08); color: rgba(245, 240, 230, 0.85); border-color: rgba(245, 240, 230, 0.15); }
  .section--ink .lc__btn { background: transparent; color: rgba(245, 240, 230, 0.7); border-color: rgba(245, 240, 230, 0.2); }
  .section--ink .lc__btn:hover { background: var(--bg); color: var(--ink); border-color: var(--bg); }
  .section--ink .h2 { color: var(--bg); }
  .section--ink .eyebrow-rule { color: rgba(245, 240, 230, 0.7); }
  .section--ink .eyebrow-rule::before, .section--ink .eyebrow-rule::after { background: rgba(245, 240, 230, 0.3); }
  .section--ink .lede { color: rgba(245, 240, 230, 0.7); }
  .section--ink .muted { color: rgba(245, 240, 230, 0.6); }
</style>
