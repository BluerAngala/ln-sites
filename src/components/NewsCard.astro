---
import type { NewsItem } from '~/lib/types';
import { t, type Locale } from '~/i18n';
import { detectLocale, prefixFor } from '~/lib/locale';

interface Props {
  news: NewsItem;
  locale?: Locale;
  showCover?: boolean;
}
const locale: Locale = Astro.props.locale ?? detectLocale(Astro.url.pathname);
const n = Astro.props.news;
const isExternal = !!n.sourceUrl;
const href = isExternal ? n.sourceUrl! : `${prefixFor(locale)}/news/${n.slug}`;
const ctaText = isExternal
  ? t({ zh: '查看原文 →', en: 'Read Original →' }, locale)
  : t({ zh: '阅读全文 →', en: 'Read More →' }, locale);
---

<a
  class="news-card-link"
  href={href}
  target={isExternal ? '_blank' : undefined}
  rel={isExternal ? 'noopener noreferrer' : undefined}
>
  <article class="news-card card">
    {
      Astro.props.showCover && n.cover && (
        <div class="news-card__cover">
          <img src={n.cover} alt={t(n.title, locale) ?? ''} loading="lazy" />
        </div>
      )
    }
    <div class="news-card__meta">
      <span class="tag tag--ink">{t(n.category, locale)}</span>
      <span class="news-card__date">{n.date}</span>
    </div>
    <h3 class="card__title">{t(n.title, locale)}</h3>
    <p class="card__excerpt">{t(n.summary, locale)}</p>
    <div class:list={['card__cta', isExternal && 'card__cta--block']}>{ctaText}</div>
  </article>
</a>

<style>
  .news-card-link {
    display: block;
    height: 100%;
  }
  .news-card-link:hover {
    text-decoration: none;
  }
  /* 卡片等高 */
  .news-card {
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .news-card__cover {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: var(--radius);
    background: var(--bg-2);
    margin: -28px -28px 20px;
  }
  .news-card__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }
  .news-card:hover .news-card__cover img {
    transform: scale(1.05);
  }
  .news-card__meta {
    display: flex;
    gap: 12px;
    align-items: center;
    margin-bottom: 4px;
  }
  .news-card__date {
    font-family: var(--serif-en);
    font-size: 12px;
    letter-spacing: 0.1em;
    color: var(--ink-soft);
  }
  .card__excerpt {
    flex-grow: 1;
  }
  .card__cta {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--rule-soft);
  }
</style>
