---
/**
 * 统一的 section 分割标题
 * - eyebrow  :小标（横线 + 主语言，由 i18n 字典按 locale 切换）
 * - title    :主标题，大字（主语言，支持 HTML 渲染如 <br/>）
 * - subtitle :次语言小字（中文为主时显示英文副标，英文为主时显示中文副标）
 * - lede     :可选副标题段落（与 subtitle 互斥，优先级更高；支持 HTML）
 * - align    :center（默认）/ left
 * - dark     :true 时在 section--ink 暗背景上使用
 */
import { t, type Locale, type I18n } from '~/i18n';

interface Props {
  eyebrow: I18n<string>;
  title: I18n<string>;
  lede?: I18n<string>;
  align?: 'left' | 'center';
  dark?: boolean;
  locale: Locale;
}
const { eyebrow, title, lede, align = 'center', dark = false, locale } = Astro.props;

const primary = t(title, locale) ?? '';
const secondary = locale === 'zh' ? (title.en ?? '') : (title.zh ?? '');
const eyebrowText = t(eyebrow, locale) ?? '';
const ledeText = lede ? (t(lede, locale) ?? '') : '';
---

<header class:list={['section-header', `section-header--${align}`, dark && 'section-header--dark']}>
  <span class="eyebrow eyebrow-rule eyebrow-rule--seal section-header__eyebrow">
    {eyebrowText}
  </span>
  <h2 class="h2 section-header__title" set:html={primary} />
  {
    ledeText ? (
      <p class="section-header__lede" set:html={ledeText} />
    ) : (
      secondary && <p class="section-header__subtitle">{secondary}</p>
    )
  }
</header>

<style>
  .section-header {
    margin-bottom: 56px;
  }
  .section-header--center {
    text-align: center;
  }
  .section-header--center .section-header__eyebrow {
    justify-content: center;
  }
  .section-header__eyebrow {
    font-size: 22px;
    font-weight: 600;
    letter-spacing: 0.16em;
    color: var(--seal);
    margin-bottom: 28px;
    gap: 18px;
  }
  .section-header__title {
    margin: 0 auto 12px;
  }
  .section-header__subtitle {
    font-family: var(--serif-en);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(14px, 1.4vw, 18px);
    letter-spacing: 0.08em;
    color: var(--ink-soft);
    margin: 0;
    line-height: 1.5;
  }
  .section-header__lede {
    font-family: var(--serif-zh);
    font-size: clamp(15px, 1.5vw, 19px);
    line-height: 1.7;
    color: var(--ink-soft);
    margin: 16px auto 0;
    max-width: 56ch;
  }
  :global(html[lang='en']) .section-header__lede {
    font-family: var(--serif-en);
    font-style: italic;
    font-size: clamp(13px, 1.3vw, 16px);
  }
  .section-header--dark .section-header__title {
    color: var(--bg);
  }
  .section-header--dark .section-header__subtitle {
    color: rgba(245, 240, 230, 0.6);
  }
  .section-header--dark .eyebrow-rule {
    color: var(--seal);
    opacity: 0.85;
  }
  .section-header--dark .eyebrow-rule::before,
  .section-header--dark .eyebrow-rule::after {
    background: var(--seal);
    opacity: 0.7;
  }
</style>
