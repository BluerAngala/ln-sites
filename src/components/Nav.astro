---
import { ut, switchLocaleUrl, DEFAULT_LOCALE, type Locale } from '~/i18n';

// 从 URL 推断（页面没传 prop 时）：/en/* → en，否则 zh
function detectLocale(): Locale {
  if (Astro.url.pathname.startsWith('/en/') || Astro.url.pathname === '/en') return 'en';
  return DEFAULT_LOCALE;
}
const locale: Locale = detectLocale();
const pathname = Astro.url.pathname;

const navItems: Array<{ key: Parameters<typeof ut>[0]; href: string; cta?: boolean }> = [
  { key: 'nav.about', href: locale === 'en' ? '/en/about' : '/about' },
  { key: 'nav.practice', href: locale === 'en' ? '/en/practice' : '/practice' },
  { key: 'nav.team', href: locale === 'en' ? '/en/team' : '/team' },
  { key: 'nav.cases', href: locale === 'en' ? '/en/cases' : '/cases' },
  { key: 'nav.news', href: locale === 'en' ? '/en/news' : '/news' },
  { key: 'nav.honors', href: locale === 'en' ? '/en/honors' : '/honors' },
  { key: 'nav.social', href: locale === 'en' ? '/en/social' : '/social' },
  { key: 'nav.contact', href: locale === 'en' ? '/en/contact' : '/contact', cta: true },
];

const homeHref = locale === 'zh' ? '/' : '/en/';
const cleanPath = pathname.replace(/^\/(en|zh)/, '') || '/';
const isActive = (href: string) => {
  const c = href.replace(/^\/(en|zh)/, '') || '/';
  return cleanPath === c || (c !== '/' && cleanPath.startsWith(c + '/'));
};
---

<header class="nav" id="nav">
  <div class="nav__inner">
    <a class="nav__brand" href={homeHref} aria-label="Lingnan">
      <span class="nav__seal" aria-hidden="true">嶺<br />南</span>
      <span class="nav__brandtext">
        <span class="nav__brandzh">岭南律师事务所</span>
        <span class="nav__branden">Lingnan · Counsel &amp; Attorneys at Law</span>
      </span>
    </a>
    <nav class="nav__menu" aria-label="Primary">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={[item.cta && 'nav__cta', isActive(item.href) && 'is-active']}
          >
            {ut(item.key, locale)}
          </a>
        ))
      }
    </nav>
    <div class="nav__lang" aria-label="Language">
      <a
        href={switchLocaleUrl(pathname, 'zh')}
        class:list={['nav__lang-link', locale === 'zh' && 'is-active']}
        aria-label="中文">中</a
      >
      <span class="nav__lang-sep">/</span>
      <a
        href={switchLocaleUrl(pathname, 'en')}
        class:list={['nav__lang-link', locale === 'en' && 'is-active']}
        aria-label="English">EN</a
      >
    </div>
    <button class="nav__toggle" aria-label="Menu" aria-expanded="false" type="button">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>
