---
/**
 * 荣誉墙：3 列 + 自下而上自动滚动的无限循环 marquee
 */
import type { Honor } from '~/lib/types';
import { t, DEFAULT_LOCALE, type Locale } from '~/i18n';

interface Props {
  honors: Honor[];
  locale?: Locale;
}
const locale: Locale = (Astro.props.locale ?? (Astro.currentLocale as Locale)) || DEFAULT_LOCALE;
const honors = Astro.props.honors;
---

<div class="honor-wall">
  <div class="honor-wall__track">
    <div class="honor-wall__set">
      {
        honors.map((h) => (
          <figure class="honor-card">
            <div class="honor-card__frame">
              {h.image ? (
                <img
                  src={h.image}
                  alt={t(h.title, locale)}
                  loading="lazy"
                  class="honor-card__img"
                />
              ) : (
                <div class="honor-card__fallback">岭南所</div>
              )}
            </div>
            <div class="honor-card__hover">
              <h4 class="honor-card__title">{t(h.title, locale)}</h4>
              <p class="honor-card__issuer">{t(h.issuer, locale)}</p>
            </div>
          </figure>
        ))
      }
    </div>
  </div>
</div>

<style>
  .honor-wall {
    position: relative;
    overflow: hidden;
    height: 76vh;
    border: 1px solid var(--rule-soft);
    background: var(--bg);
    margin: 0 calc(var(--pad-x) * -1);
  }
  .honor-wall__track {
    position: relative;
    will-change: transform;
  }
  .honor-wall__set {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    padding: 20px;
  }
  @media (max-width: 900px) {
    .honor-wall__set {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 600px) {
    .honor-wall__set {
      grid-template-columns: 1fr;
    }
  }

  .honor-card {
    position: relative;
    margin: 0;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--bg-2);
    border: 1px solid var(--rule-soft);
    cursor: zoom-in;
  }
  .honor-card__frame {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    overflow: hidden;
  }
  .honor-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition:
      transform 0.6s cubic-bezier(0.2, 0.7, 0.2, 1),
      filter 0.4s ease;
  }
  .honor-card:hover .honor-card__img {
    transform: scale(1.04);
    filter: brightness(0.5);
  }

  .honor-card__fallback {
    font-family: var(--serif-zh);
    font-weight: 500;
    font-size: 28px;
    color: var(--ink-soft);
  }

  .honor-card__hover {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 18px 16px;
    opacity: 0;
    transition: opacity 0.35s ease;
    color: var(--bg);
    background: linear-gradient(180deg, rgba(10, 8, 6, 0) 30%, rgba(10, 8, 6, 0.85) 100%);
    pointer-events: none;
  }
  .honor-card:hover .honor-card__hover {
    opacity: 1;
  }
  .honor-card__title {
    margin: 0 0 4px;
    font-size: 14px;
    font-weight: 500;
    line-height: 1.4;
    font-family: var(--serif-zh);
    letter-spacing: 0.02em;
  }
  .honor-card__issuer {
    margin: 0;
    font-size: 11px;
    color: rgba(245, 240, 230, 0.75);
    font-family: var(--serif-zh);
    line-height: 1.5;
  }
</style>

<script>
  const wall = document.querySelector<HTMLElement>('.honor-wall');
  if (wall) {
    const track = wall.querySelector<HTMLElement>('.honor-wall__track');
    const set = wall.querySelector<HTMLElement>('.honor-wall__set');
    if (track && set) {
      // 克隆一组拼接到底部，实现无限滚动
      track.appendChild(set.cloneNode(true));

      const SPEED = 80; // px/s（自下而上滚动）
      let offset = 0; // translateY（负值 = 向上移动）
      let auto = true;
      let last = performance.now();

      const tick = (now: number) => {
        const dt = now - last;
        last = now;
        if (auto) {
          offset -= (SPEED * dt) / 1000;
          const half = set.offsetHeight; // 一组卡片的高度
          if (-offset >= half) offset += half;
          track.style.transform = `translateY(${offset}px)`;
        }
        requestAnimationFrame(tick);
      };

      // 鼠标悬停在荣誉卡上时暂停
      wall.addEventListener('mouseover', (e) => {
        if ((e.target as HTMLElement).closest('.honor-card')) auto = false;
      });
      wall.addEventListener('mouseout', (e) => {
        const leaving = (e.target as HTMLElement).closest('.honor-card');
        const entering = (e.relatedTarget as HTMLElement)?.closest?.('.honor-card');
        if (leaving && !entering) {
          auto = true;
          last = performance.now();
        }
      });

      document.addEventListener('visibilitychange', () => {
        if (document.hidden) auto = false;
        else {
          auto = true;
          last = performance.now();
        }
      });

      requestAnimationFrame(tick);
    }
  }
</script>
