---
import { getOffices } from '~/lib/content';
import { t, ut, type Locale } from '~/i18n';
import { detectLocale, prefixFor, localizedHref } from '~/lib/locale';
import { getSiteConfig, getPractices } from '~/lib/content';

const locale: Locale = detectLocale(Astro.url.pathname);
const prefix = prefixFor(locale);
const offices = await getOffices();
const hq = offices.find((o) => o.isHeadquarters) ?? offices[0];
const config = await getSiteConfig();
const practices = await getPractices();
const copyright = config.copyright[locale] ?? config.copyright.zh;
const address = t(config.contactAddress, locale) ?? '';
const phone = config.contactPhone;
const email = config.contactEmail;
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__top">
      <div>
        <div class="footer__brand">广东岭南律师事务所</div>
        <div class="footer__branden">Lingnan · Counsel &amp; Attorneys at Law</div>
        <p class="footer__lead">{ut('footer.lead', locale)}</p>
      </div>

      <div class="footer__col">
        <h4>{ut('nav.practice', locale)}</h4>
        <ul>
          {
            practices.map((p) => (
              <li>
                <a href={localizedHref(`/practice?area=${p.id}`, locale)} data-practice-link={p.id}>
                  {t(p.name, locale)}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="footer__col">
        <h4>{ut('nav.about', locale)}</h4>
        <ul>
          <li><a href={localizedHref('/about', locale)}>{ut('nav.about', locale)}</a></li>
          <li><a href={localizedHref('/team', locale)}>{ut('nav.team', locale)}</a></li>
          <li><a href={localizedHref('/honors', locale)}>{ut('nav.honors', locale)}</a></li>
          <li><a href={localizedHref('/news', locale)}>{ut('nav.news', locale)}</a></li>
          <li><a href={localizedHref('/social', locale)}>{ut('nav.social', locale)}</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h4>{ut('nav.contact', locale)}</h4>
        <ul>
          {hq ? <li>{address}</li> : null}
          {
            phone ? (
              <li>
                <a href={`tel:${phone.replace(/\s/g, '')}`}>{phone}</a>
              </li>
            ) : null
          }
          {
            email ? (
              <li>
                <a href={`mailto:${email}`}>{email}</a>
              </li>
            ) : null
          }
          <li>
            <a href={localizedHref('/contact', locale)}>{ut('contact.submit' as any, locale)}</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <span
        >{copyright}
        <span style="margin-left: 12px;">·</span>
        <a
          href="https://lawyerch.feishu.cn/wiki/SzKVwp7PMizeQ4kT2RpcGUppnle?fromScene=spaceOverview"
          target="_blank"
          rel="noopener noreferrer"
          style="margin-left: 8px;">由陈恒律师独立开发与维护</a
        ></span
      >
      <a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener noreferrer"
        >{config.icpNo}</a
      >
    </div>
  </div>
</footer>
