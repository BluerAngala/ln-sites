---
import '~/styles/global.css';
import Nav from '~/components/Nav.astro';
import Footer from '~/components/Footer.astro';
import { DEFAULT_LOCALE, type Locale } from '~/i18n';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  pageClass?: string;
  hideFooter?: boolean;
}

const { title, description, ogImage, pageClass = '', hideFooter = false } = Astro.props;
const locale: Locale = (() => {
  if (Astro.url.pathname.startsWith('/en/') || Astro.url.pathname === '/en') return 'en' as Locale;
  return DEFAULT_LOCALE;
})();
const siteName = process.env.PUBLIC_SITE_NAME ?? '广东岭南律师事务所';
const siteNameEn = process.env.PUBLIC_SITE_NAME_EN ?? 'Lingnan · Counsel & Attorneys at Law';
const siteNameLocalized = locale === 'en' ? siteNameEn : siteName;

const fullTitle = title ? `${title} · ${siteNameLocalized}` : `${siteNameLocalized}`;
const fullDescription =
  description ??
  (locale === 'en'
    ? 'Lingnan Counsel & Attorneys at Law, founded in 1984 by the Law Faculty of Sun Yat-sen University. One of the largest and most established full-service law firms in South China.'
    : '广东岭南律师事务所创立于 1984 年，由中山大学法律系创办。华南地区历史最悠久、规模最大的综合性律师事务所之一。');

const canonical = new URL(
  Astro.url.pathname,
  process.env.PUBLIC_SITE_URL ?? 'https://www.lingnanlaw.com',
);
---

<!doctype html>
<html lang={locale === 'en' ? 'en' : 'zh-CN'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={fullDescription} />
    <link rel="canonical" href={canonical.href} />
    {
      locale === 'en' && (
        <link rel="alternate" hreflang="zh" href={canonical.href.replace('/en', '')} />
      )
    }
    {
      locale === 'zh' && (
        <link rel="alternate" hreflang="en" href={canonical.href.replace(/\/$/, '') + '/en'} />
      )
    }

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={fullDescription} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:site_name" content={siteNameLocalized} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300..600&family=Cormorant+Garamond:ital,wght@0,400..600;1,400..600&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body class={pageClass} data-locale={locale}>
    <a href="#main" class="sr-only">Skip to main content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    {!hideFooter && <Footer />}
    <script>
      const nav = document.querySelector('.nav');
      if (nav) {
        const onScroll = () => nav.classList.toggle('is-scrolled', window.scrollY > 8);
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }
      const toggle = document.querySelector('.nav__toggle');
      if (toggle) {
        toggle.addEventListener('click', () => {
          document.querySelector('.nav')?.classList.toggle('is-open');
        });
      }
    </script>
  </body>
</html>
