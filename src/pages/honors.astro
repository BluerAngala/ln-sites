---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SectionHeader from '~/components/SectionHeader.astro';
import HonorWall from '~/components/HonorWall.astro';
import { getHonors } from '~/lib/content';
import { t, type Locale } from '~/i18n';
import { detectLocale } from '~/lib/locale';

const locale: Locale = detectLocale(Astro.url.pathname);
const honors = await getHonors();
---

<BaseLayout title={t({ zh: '荣誉奖项', en: 'Honors' }, locale)}>
  <section class="section--tight">
    <div class="container">
      <SectionHeader
        eyebrow={{ zh: 'Honors · 荣誉', en: 'Honors' }}
        title={{
          zh: '为律师谋发展 · 为法治作贡献',
          en: 'For Lawyers · For the Rule of Law',
        }}
        lede={{
          zh: '不断创新专业服务模式，勇于承担社会责任和行业责任。',
          en: 'Constantly innovating in professional service delivery, embracing social and industry responsibility.',
        }}
        locale={locale}
      />
    </div>
  </section>

  <section class="section--tight" style="padding-top: 0;">
    <div class="container">
      <HonorWall honors={honors} locale={locale} />
    </div>
  </section>
</BaseLayout>
