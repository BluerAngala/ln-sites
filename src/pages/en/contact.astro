---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SectionHeader from '~/components/SectionHeader.astro';
import { getOffices, getSiteConfig } from '~/lib/content';
import { t, type Locale } from '~/i18n';

const locale: Locale = 'en' as const;
const offices = await getOffices();
const config = await getSiteConfig();
const hq = offices.find((o) => o.isHeadquarters) ?? offices[0];
---

<BaseLayout title={t({ zh: '委托咨询', en: 'Contact' }, locale)}>
  <section class="section--tight">
    <div class="container">
      <SectionHeader
        eyebrow={{ zh: 'Contact · 委托', en: 'Contact' }}
        title={{ zh: '一份委托 · 一份郑重', en: 'An Engagement · A Commitment' }}
        lede={{
          zh: '请填写以下表单或直接致电总所。',
          en: 'Please fill out the form below or call the headquarters directly.',
        }}
        locale={locale}
      />
    </div>
  </section>

  <section class="section--tight" style="padding-top: 0;">
    <div class="container">
      <div class="grid grid--2" style="gap: clamp(40px, 6vw, 100px); align-items: start;">
        <form
          class="contact-form"
          action="https://formspree.io/f/your-form-id"
          method="POST"
          data-stub
        >
          <div class="form-row">
            <label
              ><span>{t({ zh: '姓名 *', en: 'Name *' }, locale)}</span><input
                type="text"
                name="name"
                required
                placeholder={t({ zh: '您的姓名', en: 'Your name' }, locale)}
              /></label
            >
            <label
              ><span>{t({ zh: '手机 *', en: 'Phone *' }, locale)}</span><input
                type="tel"
                name="phone"
                required
                placeholder="138 0000 0000"
              /></label
            >
          </div>
          <div class="form-row">
            <label
              ><span>{t({ zh: '邮箱', en: 'Email' }, locale)}</span><input
                type="email"
                name="email"
                placeholder="you@example.com"
              /></label
            >
            <label
              ><span>{t({ zh: '单位', en: 'Company' }, locale)}</span><input
                type="text"
                name="company"
                placeholder={t({ zh: '所在公司 / 单位', en: 'Your company' }, locale)}
              /></label
            >
          </div>
          <label>
            <span>{t({ zh: '业务类型 *', en: 'Practice Area *' }, locale)}</span>
            <select name="practice" required>
              <option value="">{t({ zh: '请选择', en: 'Please select' }, locale)}</option>
              <option>{t({ zh: '公司商事', en: 'Corporate & Commercial' }, locale)}</option>
              <option>{t({ zh: '争议解决', en: 'Dispute Resolution' }, locale)}</option>
              <option>{t({ zh: '知识产权', en: 'Intellectual Property' }, locale)}</option>
              <option>{t({ zh: '刑事辩护', en: 'Criminal Defense' }, locale)}</option>
              <option>{t({ zh: '资本市场', en: 'Capital Markets' }, locale)}</option>
              <option>{t({ zh: '跨境投资', en: 'Cross-border Investment' }, locale)}</option>
              <option>{t({ zh: '房地产与建设工程', en: 'Real Estate' }, locale)}</option>
              <option>{t({ zh: '金融与资管', en: 'Finance' }, locale)}</option>
              <option>{t({ zh: '其他', en: 'Other' }, locale)}</option>
            </select>
          </label>
          <label>
            <span>{t({ zh: '案情简述 *', en: 'Matter Description *' }, locale)}</span>
            <textarea
              name="message"
              rows="6"
              required
              placeholder={t(
                { zh: '请简要说明您的需求与背景', en: 'Briefly describe your needs' },
                locale,
              )}></textarea>
          </label>
          <button type="submit" class="btn btn--solid btn--full"
            >{t({ zh: '提交委托', en: 'Submit' }, locale)} →</button
          >
          <p class="form-hint">
            {
              t(
                {
                  zh: '提交即代表您同意我们将上述信息用于本次咨询。岭南所承诺保密。',
                  en: 'By submitting, you agree to our use of this information. Lingnan ensures confidentiality.',
                },
                locale,
              )
            }
          </p>
        </form>

        <aside class="contact-aside">
          <div class="contact-block">
            <span class="eyebrow eyebrow-rule">{t({ zh: '总所', en: 'Headquarters' }, locale)}</span
            >
            {
              hq && (
                <div style="margin-top: 16px;">
                  <p style="font-size: 18px; line-height: 1.7; margin: 0 0 16px;">
                    {t(config.contactAddress, locale)}
                  </p>
                  <p style="margin: 0 0 8px;">
                    <strong>📞 {t({ zh: '电话', en: 'Tel' }, locale)}</strong>{' '}
                    <a href={`tel:${config.contactPhone.replace(/\s/g, '')}`}>
                      {config.contactPhone}
                    </a>
                  </p>
                  <p style="margin: 0;">
                    <strong>✉️ {t({ zh: '邮箱', en: 'Email' }, locale)}</strong>{' '}
                    <a href={`mailto:${config.contactEmail}`}>{config.contactEmail}</a>
                  </p>
                </div>
              )
            }
          </div>

          <div class="contact-block" style="margin-top: 40px;">
            <span class="eyebrow eyebrow-rule">{t({ zh: '分所', en: 'Branches' }, locale)}</span>
            <ul style="margin-top: 16px;">
              {
                offices
                  .filter((o) => !o.isHeadquarters)
                  .map((o) => (
                    <li style="padding: 8px 0; border-bottom: 1px solid var(--rule-soft); font-size: 14px;">
                      <strong>{t(o.city, locale)}</strong>
                      <span class="muted"> · {o.phone}</span>
                    </li>
                  ))
              }
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  @media (max-width: 600px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
  .contact-form label {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .contact-form label > span {
    font-size: 13px;
    color: var(--ink-soft);
  }
  .contact-form input,
  .contact-form select,
  .contact-form textarea {
    padding: 12px 14px;
    font: inherit;
    color: var(--ink);
    background: var(--bg-soft);
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    transition: border-color 0.2s;
  }
  .contact-form input:focus,
  .contact-form select:focus,
  .contact-form textarea:focus {
    outline: 0;
    border-color: var(--ink);
  }
  .form-hint {
    font-size: 12px;
    color: var(--ink-soft);
    margin: 0;
  }
  .contact-block strong {
    font-weight: 500;
  }
  .contact-block a {
    color: var(--seal);
    border-bottom: 1px solid currentColor;
  }
</style>

<script>
  document.querySelectorAll('form[data-stub]').forEach((form) => {
    form.addEventListener('submit', (e) => {
      const action = (form as HTMLFormElement).getAttribute('action') || '';
      if (action.includes('your-form-id')) {
        e.preventDefault();
        alert('Form backend not configured. Update action in src/pages/contact.astro.');
      }
    });
  });
</script>
