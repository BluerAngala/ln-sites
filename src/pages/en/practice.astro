---
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageHero from '~/components/PageHero.astro';
import { getPractices, getCases } from '~/lib/content';
import { t, type Locale } from '~/i18n';

const locale: Locale = 'en' as const;
const practices = await getPractices();
const cases = await getCases();
const casesByArea: Record<string, typeof cases> = {};
for (const c of cases) {
  const k = c.practiceArea?.[locale] ?? c.practiceArea?.zh;
  if (!k) continue;
  (casesByArea[k] ??= []).push(c);
}
---

<BaseLayout title={t({ zh: '业务领域', en: 'Practice Areas' }, locale) ?? 'Practice Areas'}>
  <PageHero
    eyebrow={t({ zh: 'Practices · 业务', en: 'Practice' }, locale) ?? 'Practice'}
    title={t({ zh: '八大方舟，一以贯之。', en: 'Eight Pillars. One Standard.' }, locale) ??
      'Eight Pillars. One Standard.'}
    lede={t(
      {
        zh: '专注于法律服务的精进与创新。',
        en: 'Focused on the refinement and innovation of legal services.',
      },
      locale,
    ) ?? ''}
  />

  <section class="section--tight" style="padding-top: 0;">
    <div class="container">
      {
        practices.map((p) => {
          const key = t(p.name, locale) ?? p.name.zh;
          const list = casesByArea[key] ?? [];
          return (
            <article
              id={p.id}
              class="practice-block"
              style="border-top: 1px solid var(--rule); padding: 60px 0;"
            >
              <div class="grid grid--2" style="gap: clamp(40px, 6vw, 100px); align-items: start;">
                <div>
                  <span class="eyebrow eyebrow-rule eyebrow-rule--seal">{p.nameEn}</span>
                  <h2 class="h2" style="margin-top: 16px;">
                    {t(p.name, locale)}
                  </h2>
                  <p class="lede">{t(p.description, locale)}</p>
                  {p.caseCount != null && (
                    <p style="margin-top: 24px; font-family: var(--serif-en); color: var(--seal); font-size: 32px; font-weight: 300;">
                      {p.caseCount}
                      <span style="font-size: 0.5em; color: var(--ink-soft);">
                        + {t({ zh: '案例', en: 'Cases' }, locale)}
                      </span>
                    </p>
                  )}
                </div>
                <div>
                  {list.length > 0 ? (
                    <ul class="practice-cases">
                      {list.slice(0, 3).map((c) => (
                        <li>
                          <a href={`/${locale}/cases/${c.slug}`}>
                            <span class="tag" style="margin-right: 12px;">
                              {t(c.type, locale)}
                            </span>
                            <span class="practice-case-title">{t(c.title, locale)}</span>
                            <span class="arrow">→</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  ) : (
                    <p class="muted" style="font-style: italic;">
                      {t(
                        {
                          zh: '代表性案例即将上线，欢迎来电咨询。',
                          en: 'Representative works coming soon.',
                        },
                        locale,
                      )}
                    </p>
                  )}
                </div>
              </div>
            </article>
          );
        })
      }
    </div>
  </section>
</BaseLayout>

<style>
  .practice-block:first-of-type {
    border-top: 0;
    padding-top: 0;
  }
  .practice-cases {
    display: flex;
    flex-direction: column;
  }
  .practice-cases li {
    border-bottom: 1px solid var(--rule-soft);
  }
  .practice-cases a {
    display: flex;
    align-items: center;
    padding: 18px 0;
    transition: color 0.2s;
    gap: 12px;
  }
  .practice-cases a:hover {
    color: var(--seal);
  }
  .practice-case-title {
    flex: 1;
    font-family: var(--serif-zh);
  }
  :global(html[lang='en']) .practice-case-title {
    font-family: var(--serif-en);
  }
  .practice-cases .arrow {
    color: var(--ink-soft);
    transition: transform 0.2s;
  }
  .practice-cases a:hover .arrow {
    transform: translateX(4px);
    color: var(--seal);
  }
</style>
