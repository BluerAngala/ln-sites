---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SectionHeader from '~/components/SectionHeader.astro';
import LawyerCases from '~/components/LawyerCases.astro';
import { getPractices, getCases, getLawyers } from '~/lib/content';
import { t, DEFAULT_LOCALE, type Locale } from '~/i18n';

const locale: Locale = (Astro.currentLocale as Locale) || DEFAULT_LOCALE;
const [practices, cases, lawyers] = await Promise.all([getPractices(), getCases(), getLawyers()]);

const prefix = locale === 'en' ? '/en' : '';

interface PracticeView {
  practice: (typeof practices)[number];
  index: number;
  matchedLawyers: typeof lawyers;
  // 律师 → 案例的映射（提前算好避免客户端 JS 算）
  lawyerCaseMap: Map<string, typeof cases>;
}
const practiceViews: PracticeView[] = practices.map((p, i) => {
  const aliases = p.aliases?.[locale] ?? [];
  const nameZh = p.name.zh;
  const matchedLawyers = lawyers
    .filter((l) => {
      const areas = l.practiceAreas[locale] ?? l.practiceAreas.zh ?? [];
      if (aliases.length > 0 && areas.some((a) => aliases.includes(a))) return true;
      return areas.includes(nameZh);
    })
    .sort((a, b) => (a.order ?? 999) - (b.order ?? 999));

  // 该领域下，每个律师关联的案例（leadLawyerId 或 lawyerIds 命中，且 practiceArea 匹配当前领域）
  const pnameZh = p.name.zh;
  const pnameEn = p.name.en;
  const lawyerCaseMap = new Map<string, typeof cases>();
  for (const l of matchedLawyers) {
    const lsCases = cases.filter(
      (c) =>
        (c.leadLawyerId === l.id || c.lawyerIds?.includes(l.id)) &&
        (c.practiceArea?.zh === pnameZh || c.practiceArea?.en === pnameEn),
    );
    lawyerCaseMap.set(l.id, lsCases);
  }

  return { practice: p, index: i, matchedLawyers, lawyerCaseMap };
});

// 序列化供客户端初始状态恢复用（URL ?area=...）
const initialAreaId = Astro.url.searchParams.get('area') ?? '';
---

<BaseLayout title={t({ zh: '业务领域', en: 'Practice Areas' }, locale)}>
  <section class="section--tight">
    <div class="container">
      <SectionHeader
        eyebrow={{ zh: '八大领域 · Practices', en: 'Eight Pillars · Practices' }}
        title={{ zh: '领域 · 人 · 案例', en: 'Area · People · Cases' }}
        locale={locale}
      />

      <p class="practice-hint">
        {
          t(
            {
              zh: '点击领域查看团队；点击律师查看案例并发起委托。',
              en: 'Click an area to see its counsel. Click a lawyer to view their cases and engage.',
            },
            locale,
          )
        }
      </p>

      <ul class="practice-areas" role="list">
        {
          practiceViews.map(({ practice, index, matchedLawyers, lawyerCaseMap }) => {
            const areaId = `area-${practice.id}`;
            return (
              <li
                class:list={['practice-area', { 'is-open': practice.id === initialAreaId }]}
                data-area-id={practice.id}
                id={areaId}
              >
                <button
                  type="button"
                  class="practice-area__head"
                  aria-expanded={practice.id === initialAreaId ? 'true' : 'false'}
                  aria-controls={`panel-${practice.id}`}
                >
                  <span class="practice-area__num">0{index + 1}</span>
                  <div class="practice-area__title">
                    <span class="practice-area__name">{t(practice.name, locale)}</span>
                    <span class="practice-area__nameEn">{practice.nameEn}</span>
                  </div>
                  <div class="practice-area__stats">
                    {practice.caseCount != null && (
                      <span class="practice-area__stat">
                        <strong>{practice.caseCount}</strong>
                        <small>{t({ zh: '案例', en: 'cases' }, locale)}</small>
                      </span>
                    )}
                    <span class="practice-area__stat">
                      <strong>{matchedLawyers.length}</strong>
                      <small>{t({ zh: '律师', en: 'lawyers' }, locale)}</small>
                    </span>
                  </div>
                  <span class="practice-area__toggle" aria-hidden="true">
                    <span class="practice-area__toggle-bar" />
                    <span class="practice-area__toggle-bar" />
                  </span>
                </button>

                <div
                  class="practice-area__panel"
                  id={`panel-${practice.id}`}
                  role="region"
                  aria-labelledby={areaId}
                  hidden={practice.id !== initialAreaId}
                >
                  <div class="practice-area__inner">
                    <p class="practice-area__desc">{t(practice.description, locale)}</p>

                    {matchedLawyers.length > 0 ? (
                      <ul class="practice-lawyers" role="list">
                        {matchedLawyers.map((l) => {
                          const lsCases = lawyerCaseMap.get(l.id) ?? [];
                          return (
                            <li class="practice-lawyer" data-lawyer-id={l.id}>
                              <div class="practice-lawyer__avatar">
                                {l.avatar ? (
                                  <img
                                    src={l.avatar}
                                    alt={t(l.name, locale) ?? ''}
                                    loading="lazy"
                                  />
                                ) : (
                                  <span>{(t(l.name, locale) ?? '?').charAt(0)}</span>
                                )}
                              </div>
                              <div class="practice-lawyer__body">
                                <div class="practice-lawyer__name">{t(l.name, locale)}</div>
                                <div class="practice-lawyer__level">{t(l.level, locale)}</div>
                                <p class="practice-lawyer__bio">{t(l.bio, locale)}</p>
                                {l.expertise && (
                                  <div class="practice-lawyer__tags">
                                    {(l.expertise[locale] ?? l.expertise.zh ?? [])
                                      .slice(0, 3)
                                      .map((tag) => (
                                        <span class="tag">{tag}</span>
                                      ))}
                                  </div>
                                )}
                                <div class="practice-lawyer__actions">
                                  {l.phone && (
                                    <a
                                      href={`tel:${l.phone.replace(/[^\d+]/g, '')}`}
                                      class="pl-action pl-action--call"
                                      onclick="evt.stopPropagation()"
                                    >
                                      {t({ zh: '☎ 直接咨询', en: '☎ Call' }, locale)}
                                    </a>
                                  )}
                                  <a
                                    href={`${prefix}/team/${l.slug}`}
                                    class="pl-action pl-action--detail"
                                    onclick="evt.stopPropagation()"
                                  >
                                    {t({ zh: '查看详情 →', en: 'View Profile →' }, locale)}
                                  </a>
                                  <button
                                    type="button"
                                    class="pl-action pl-action--cases"
                                    data-lawyer-name={t(l.name, locale) ?? ''}
                                    data-lawyer-level={t(l.level, locale) ?? ''}
                                    data-area-name={t(practice.name, locale) ?? ''}
                                    onclick="evt.stopPropagation()"
                                  >
                                    {t({ zh: '代表案例 ▾', en: 'Cases ▾' }, locale)}{' '}
                                    <span class="pl-action__count">{lsCases.length}</span>
                                  </button>
                                </div>
                              </div>
                            </li>
                          );
                        })}
                      </ul>
                    ) : (
                      <p class="practice-area__empty">
                        {t(
                          {
                            zh: '该领域律师信息即将上线，欢迎来电垂询。',
                            en: 'Counsel for this area coming soon. Please contact us directly.',
                          },
                          locale,
                        )}
                      </p>
                    )}
                  </div>
                </div>
              </li>
            );
          })
        }
      </ul>
    </div>
  </section>
</BaseLayout>

{/* ========== 全局弹窗容器（一个即可，所有律师案例都注入这里） ========== */}
<div id="lawyer-modal" class="lawyer-modal" hidden>
  <div class="lawyer-modal__backdrop" data-modal-close></div>
  <div
    class="lawyer-modal__dialog"
    role="dialog"
    aria-modal="true"
    aria-labelledby="lawyer-modal-title"
  >
    <header class="lawyer-modal__head">
      <div>
        <div class="eyebrow eyebrow-rule eyebrow-rule--seal" id="lawyer-modal-area"></div>
        <h2 class="lawyer-modal__title" id="lawyer-modal-title"></h2>
        <div class="lawyer-modal__level" id="lawyer-modal-level"></div>
      </div>
      <button type="button" class="lawyer-modal__close" data-modal-close aria-label="Close"
        >×</button
      >
    </header>
    <div class="lawyer-modal__body" id="lawyer-modal-body"></div>
    <footer class="lawyer-modal__foot">
      <a id="lawyer-modal-engage" class="lawyer-modal__cta" href="#">
        {t({ zh: '委托咨询此律师 →', en: 'Engage this counsel →' }, locale)}
      </a>
    </footer>
  </div>
</div>

{/* 隐藏数据源：每个律师的案例 HTML 片段都提前渲染好，客户端按需注入 */}
<div id="lawyer-modal-data" hidden aria-hidden="true">
  {
    practiceViews.map(({ matchedLawyers, lawyerCaseMap }) =>
      matchedLawyers.map((l) => {
        const lsCases = lawyerCaseMap.get(l.id) ?? [];
        return (
          <div
            data-lawyer-payload={l.id}
            data-lawyer-engage-href={`${prefix}/contact?for=${l.slug}`}
          >
            <LawyerCases cases={lsCases} locale={locale} prefix={prefix} compact={true} />
          </div>
        );
      }),
    )
  }
</div>

<script is:inline>
  (() => {
    const modal = document.getElementById('lawyer-modal');
    const body = document.getElementById('lawyer-modal-body');
    const titleEl = document.getElementById('lawyer-modal-title');
    const levelEl = document.getElementById('lawyer-modal-level');
    const areaEl = document.getElementById('lawyer-modal-area');
    const engageEl = document.getElementById('lawyer-modal-engage');
    const dataBox = document.getElementById('lawyer-modal-data');
    if (!modal || !body || !dataBox) return;

    // 打开弹窗
    const openModal = (lawyerId) => {
      const trigger = document.querySelector(`[data-lawyer-id="${lawyerId}"]`);
      if (!trigger) return;
      const btn = trigger.querySelector('.pl-action--cases');
      const payloadEl = dataBox.querySelector(`[data-lawyer-payload="${lawyerId}"]`);
      if (!btn || !payloadEl) return;

      titleEl.textContent = btn.dataset.lawyerName || '';
      levelEl.textContent = btn.dataset.lawyerLevel || '';
      areaEl.textContent = btn.dataset.areaName || '';
      engageEl.setAttribute('href', payloadEl.dataset.lawyerEngageHref || '#');

      body.innerHTML = '';
      const inner =
        payloadEl.querySelector('.lawyer-cases') || payloadEl.querySelector('.lawyer-cases__empty');
      if (inner) body.appendChild(inner.cloneNode(true));

      modal.hidden = false;
      document.body.style.overflow = 'hidden';
      modal.querySelector('.lawyer-modal__close')?.focus();
    };

    // 关闭弹窗
    const closeModal = () => {
      modal.hidden = true;
      document.body.style.overflow = '';
      if (pendingLawyerId) {
        pendingLawyerId = '';
        const url = new URL(window.location.href);
        url.searchParams.delete('lawyer');
        history.replaceState(null, '', url);
      }
    };

    // 弹窗事件
    document.querySelectorAll('[data-modal-close]').forEach((el) => {
      el.addEventListener('click', closeModal);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.hidden) closeModal();
    });

    // 律师"案例"按钮点击
    document.querySelectorAll('.pl-action--cases').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const card = btn.closest('.practice-lawyer');
        const lawyerId = card?.dataset.lawyerId;
        if (!lawyerId) return;
        openModal(lawyerId);
        // URL 同步
        const url = new URL(window.location.href);
        url.searchParams.set('lawyer', lawyerId);
        const areaEl2 = card?.closest('.practice-area');
        if (areaEl2?.dataset.areaId) url.searchParams.set('area', areaEl2.dataset.areaId);
        history.pushState(null, '', url);
      });
    });

    // 领域手风琴
    const areaHeaders = document.querySelectorAll('.practice-area__head');
    areaHeaders.forEach((head) => {
      head.addEventListener('click', () => {
        const area = head.closest('.practice-area');
        const panel = area?.querySelector('.practice-area__panel');
        if (!area || !panel) return;
        const isOpen = area.classList.toggle('is-open');
        head.setAttribute('aria-expanded', String(isOpen));
        panel.hidden = !isOpen;

        const url = new URL(window.location.href);
        if (isOpen) {
          url.searchParams.set('area', area.dataset.areaId || '');
        } else {
          url.searchParams.delete('area');
          url.searchParams.delete('lawyer');
        }
        history.replaceState(null, '', url);
      });
    });

    // 初始化：URL ?area= 恢复展开
    let pendingLawyerId = new URL(window.location.href).searchParams.get('lawyer');
    const initialArea = new URL(window.location.href).searchParams.get('area');
    if (initialArea) {
      const target = document.querySelector(`.practice-area[data-area-id="${initialArea}"]`);
      if (target) {
        target.classList.add('is-open');
        target.querySelector('.practice-area__head')?.setAttribute('aria-expanded', 'true');
        const p = target.querySelector('.practice-area__panel');
        if (p) p.hidden = false;
        setTimeout(() => target.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
      }
    }
    if (pendingLawyerId) {
      setTimeout(() => openModal(pendingLawyerId), 200);
    }

    // 浏览器前进/后退
    window.addEventListener('popstate', () => {
      closeModal();
      const area = new URL(window.location.href).searchParams.get('area');
      document.querySelectorAll('.practice-area').forEach((a) => {
        const open = a.dataset.areaId === area;
        a.classList.toggle('is-open', open);
        a.querySelector('.practice-area__head')?.setAttribute('aria-expanded', String(open));
        a.querySelector('.practice-area__panel').hidden = !open;
      });
    });
  })();
</script>

<style>
  /* === 提示语 === */
  .practice-hint {
    text-align: center;
    font-family: var(--serif-en);
    font-style: italic;
    font-size: 14px;
    color: var(--ink-soft);
    margin: 0 0 40px;
  }
  :global(html[lang='en']) .practice-hint {
    font-style: italic;
  }

  /* === 领域列表 === */
  .practice-areas {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--rule);
  }
  .practice-area {
    border-bottom: 1px solid var(--rule);
  }
  .practice-area.is-open {
    background: var(--bg-2);
  }

  .practice-area__head {
    display: grid;
    grid-template-columns: 80px 1fr auto 32px;
    align-items: center;
    gap: 24px;
    width: 100%;
    padding: 28px 24px;
    background: transparent;
    border: 0;
    cursor: pointer;
    text-align: left;
    color: inherit;
    font: inherit;
    transition: background 0.2s;
  }
  .practice-area__head:hover {
    background: var(--bg-2);
  }
  .practice-area.is-open .practice-area__head {
    background: transparent;
  }

  .practice-area__num {
    font-family: var(--serif-en);
    font-size: 36px;
    font-weight: 200;
    color: var(--seal);
    line-height: 1;
    letter-spacing: 0.04em;
  }
  .practice-area__title {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .practice-area__name {
    font-family: var(--serif-zh);
    font-weight: 500;
    font-size: 22px;
    line-height: 1.3;
    color: var(--ink);
  }
  :global(html[lang='en']) .practice-area__name {
    font-family: var(--serif-en);
    font-size: 20px;
  }
  .practice-area__nameEn {
    font-family: var(--serif-en);
    font-style: italic;
    font-size: 13px;
    color: var(--ink-soft);
    letter-spacing: 0.04em;
  }
  .practice-area__stats {
    display: flex;
    gap: 24px;
  }
  .practice-area__stat {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    line-height: 1;
  }
  .practice-area__stat strong {
    font-family: var(--serif-en);
    font-size: 22px;
    font-weight: 300;
    color: var(--ink);
  }
  .practice-area__stat small {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-top: 6px;
  }
  @media (max-width: 700px) {
    .practice-area__head {
      grid-template-columns: 56px 1fr 32px;
      gap: 16px;
      padding: 20px 16px;
    }
    .practice-area__stats {
      display: none;
    }
    .practice-area__num {
      font-size: 28px;
    }
    .practice-area__name {
      font-size: 18px;
    }
  }

  /* +/- 切换图标 */
  .practice-area__toggle {
    position: relative;
    width: 24px;
    height: 24px;
  }
  .practice-area__toggle-bar {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 16px;
    height: 1.5px;
    background: var(--ink);
    transform: translate(-50%, -50%);
    transition:
      transform 0.25s,
      opacity 0.25s;
  }
  .practice-area__toggle-bar:last-child {
    transform: translate(-50%, -50%) rotate(90deg);
  }
  .practice-area.is-open .practice-area__toggle-bar:last-child {
    transform: translate(-50%, -50%) rotate(0deg);
    opacity: 0;
  }

  /* 展开区 */
  .practice-area__panel {
    overflow: hidden;
  }
  .practice-area__inner {
    padding: 8px 24px 40px;
    max-width: 100%;
  }
  @media (max-width: 700px) {
    .practice-area__inner {
      padding: 0 16px 32px;
    }
  }
  .practice-area__desc {
    font-family: var(--serif-zh);
    font-size: 15px;
    line-height: 1.8;
    color: var(--ink-soft);
    margin: 0 0 24px;
    max-width: 80ch;
  }
  :global(html[lang='en']) .practice-area__desc {
    font-family: var(--serif-en);
    font-size: 14px;
  }
  .practice-area__empty {
    font-size: 14px;
    color: var(--ink-soft);
    font-style: italic;
    margin: 0;
    padding: 24px 0;
  }

  /* === 律师列表（手风琴第二层不用，每张卡就显示完整，三按钮触发动作） === */
  .practice-lawyers {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }
  @media (max-width: 700px) {
    .practice-lawyers {
      grid-template-columns: 1fr;
    }
  }

  .practice-lawyer {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 18px;
    padding: 20px;
    background: var(--bg);
    border: 1px solid var(--rule-soft);
    transition:
      border-color 0.2s,
      transform 0.2s;
  }
  .practice-lawyer:hover {
    border-color: var(--seal);
  }

  .practice-lawyer__avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--bg-2);
    display: grid;
    place-items: center;
  }
  .practice-lawyer__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }
  .practice-lawyer__avatar span {
    font-family: var(--serif-zh);
    font-size: 28px;
    color: var(--ink-soft);
  }

  .practice-lawyer__name {
    font-family: var(--serif-zh);
    font-weight: 500;
    font-size: 18px;
    color: var(--ink);
  }
  :global(html[lang='en']) .practice-lawyer__name {
    font-family: var(--serif-en);
  }
  .practice-lawyer__level {
    font-family: var(--serif-en);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--seal);
    margin: 2px 0 8px;
  }
  .practice-lawyer__bio {
    font-size: 13px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0 0 10px;
    font-family: var(--serif-zh);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  :global(html[lang='en']) .practice-lawyer__bio {
    font-family: var(--serif-en);
  }
  .practice-lawyer__tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }
  .practice-lawyer__tags .tag {
    font-family: var(--serif-zh);
    font-size: 11px;
    padding: 2px 8px;
    background: var(--bg-2);
    color: var(--ink-soft);
    border-radius: 2px;
  }

  /* 三按钮 */
  .practice-lawyer__actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .pl-action {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 7px 12px;
    font-family: var(--serif-zh);
    font-size: 12px;
    letter-spacing: 0.04em;
    text-decoration: none;
    background: transparent;
    border: 1px solid var(--rule);
    color: var(--ink);
    cursor: pointer;
    transition: all 0.2s;
  }
  :global(html[lang='en']) .pl-action {
    font-family: var(--serif-en);
    font-size: 11px;
  }
  .pl-action:hover {
    background: var(--ink);
    color: var(--bg);
    border-color: var(--ink);
  }
  .pl-action--call {
    color: var(--seal);
    border-color: var(--seal);
  }
  .pl-action--call:hover {
    background: var(--seal);
    color: var(--bg);
    border-color: var(--seal);
  }
  .pl-action__count {
    font-family: var(--serif-en);
    font-size: 10px;
    background: var(--bg-2);
    color: var(--ink-soft);
    padding: 1px 5px;
    border-radius: 8px;
    margin-left: 4px;
  }
  .pl-action--cases:hover .pl-action__count {
    background: rgba(245, 240, 230, 0.2);
    color: var(--bg);
  }

  /* === 弹窗 === */
  .lawyer-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: grid;
    place-items: center;
    padding: 24px;
  }
  .lawyer-modal[hidden] {
    display: none;
  }
  .lawyer-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  .lawyer-modal__dialog {
    position: relative;
    background: var(--bg);
    max-width: 720px;
    width: 100%;
    max-height: calc(100vh - 48px);
    display: flex;
